{% extends 'base.html.twig' %}

{% block title %}Recherche "{{ query }}" - Bella Couture{% endblock %}
{% block meta_description %}Resultats de recherche Bella Couture pour "{{ query }}": trouvez des vetements femme, tailles et couleurs disponibles dans la boutique.{% endblock %}
{% block robots %}noindex, follow{% endblock %}
{% block canonical_url %}{{ app.request.schemeAndHttpHost ~ path('search', {'q': query}) }}{% endblock %}

{% block body %}
    <section class="bc-page-hero pb-3">
        <div class="container">
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ path('home') }}">Accueil</a></li>
                    <li class="breadcrumb-item"><a href="{{ path('products') }}">Boutique</a></li>
                    <li class="breadcrumb-item active">Recherche</li>
                </ol>
            </nav>

            <div class="row align-items-end g-4">
                <div class="col-lg-8">
                    <span class="page-kicker">Recherche</span>
                    <h1 class="display-6 mb-3">Resultats pour "{{ query }}"</h1>
                    <p class="section-subtitle mb-0">
                        {% if resultsCount > 0 %}
                            {{ resultsCount }} produit(s) correspondent a votre recherche.
                        {% else %}
                            Aucun produit ne correspond encore a cette recherche.
                        {% endif %}
                    </p>
                </div>
                <div class="col-lg-4 text-lg-end">
                    <a href="{{ path('products') }}" class="btn btn-outline-primary">Voir toute la collection</a>
                </div>
            </div>
        </div>
    </section>

    <div class="container mb-5">
        <div class="row g-4">
            <aside class="col-lg-3">
                <div class="card bc-filter-card">
                    <div class="card-header">
                        <h5 class="mb-0">Affiner</h5>
                    </div>
                    <div class="card-body">
                        <form method="GET" action="{{ path('search') }}">
                            <div class="mb-3">
                                <label for="searchQuery" class="form-label">Recherche</label>
                                <input type="text" class="form-control" id="searchQuery" name="q" value="{{ query }}" placeholder="Rechercher...">
                            </div>

                            <div class="mb-3">
                                <label for="searchCategory" class="form-label">Categorie</label>
                                <select name="category" id="searchCategory" class="form-select">
                                    <option value="">Toutes les categories</option>
                                    {% for category in categories %}
                                        <option value="{{ category.slug }}" {{ currentCategory == category.slug ? 'selected' : '' }}>
                                            {{ category.name }}
                                        </option>
                                    {% endfor %}
                                </select>
                            </div>

                            <button type="submit" class="btn btn-primary w-100">
                                <i class="fas fa-search me-2"></i> Rechercher
                            </button>
                        </form>
                    </div>
                </div>
            </aside>

            <main class="col-lg-9">
                {% if products|length > 0 %}
                    <div class="row g-4">
                        {% for product in products %}
                            <div class="col-xl-4 col-md-6">
                                <div class="card product-card h-100">
                                    {% if product.images|length > 0 %}
                                        <img src="{{ asset('uploads/products/' ~ product.images.first.filename) }}" class="card-img-top" alt="{{ product.name }}" onerror="this.onerror=null; this.src='{{ asset('images/placeholder.svg') }}';">
                                    {% else %}
                                        <img src="{{ asset('images/placeholder.svg') }}" class="card-img-top" alt="Image non disponible">
                                    {% endif %}

                                    <div class="card-body d-flex flex-column">
                                        <div class="d-flex justify-content-between gap-2 align-items-start mb-2">
                                            <h5 class="card-title mb-0">{{ product.name }}</h5>
                                            {% if product.category %}
                                                <span class="badge bg-info">{{ product.category.name }}</span>
                                            {% endif %}
                                        </div>
                                        <p class="card-text text-muted small flex-grow-1">
                                            {{ product.description|length > 96 ? product.description|slice(0, 96) ~ '...' : product.description }}
                                        </p>
                                        <p class="h5 text-primary mb-3">{{ product.price }} DT</p>
                                        <div class="d-flex flex-wrap gap-1 mb-3">
                                            {% for size in product.sizes|slice(0, 4) %}
                                                <span class="badge bg-light text-dark">{{ size.name }}</span>
                                            {% endfor %}
                                            {% for color in product.colors|slice(0, 3) %}
                                                <span class="badge bg-light text-dark">{{ color }}</span>
                                            {% endfor %}
                                        </div>
                                        <div class="d-grid gap-2 mt-auto">
                                            {% if product.quantity > 0 %}
                                                <a href="{{ path('product_detail', {'id': product.id}) }}" class="btn btn-primary">
                                                    <i class="fas fa-ruler-combined me-1"></i> Choisir taille et couleur
                                                </a>
                                            {% else %}
                                                <button class="btn btn-outline-secondary w-100" disabled>Rupture de stock</button>
                                            {% endif %}
                                            <a href="{{ path('product_detail', {'id': product.id}) }}" class="btn btn-outline-primary">Voir details</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="bc-empty-state text-center py-5 px-3">
                        <i class="fas fa-search fa-3x text-primary mb-3"></i>
                        <h3>Aucun resultat trouve</h3>
                        <p class="text-muted mb-4">Essayez un mot plus simple, une autre categorie, ou revenez a toute la collection.</p>
                        <div class="d-flex gap-2 justify-content-center flex-wrap">
                            <a href="{{ path('products') }}" class="btn btn-primary">Voir tous les produits</a>
                            <a href="{{ path('home') }}" class="btn btn-outline-primary">Retour accueil</a>
                        </div>
                    </div>
                {% endif %}
            </main>
        </div>
    </div>
{% endblock %}
