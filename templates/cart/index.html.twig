{% extends 'base.html.twig' %}

{% block title %}Mon panier - Bella Couture{% endblock %}
{% block robots %}noindex, nofollow{% endblock %}
{% block canonical_url %}{{ app.request.schemeAndHttpHost ~ path('cart') }}{% endblock %}

{% block body %}
    <section class="bc-page-hero pb-3">
        <div class="container">
            <span class="page-kicker">Votre selection</span>
            <h1 class="display-6 mb-2">Mon panier</h1>
            <p class="section-subtitle mb-0">Verifiez vos articles avant de passer commande. Les promotions appliquees sont deja calculees.</p>
        </div>
    </section>

    <div class="container mb-5">
        {% if cartData|length > 0 %}
            {% set shipping = shippingFee %}
            {% set totalDiscount = 0 %}
            {% for item in cartData %}
                {% if item.promotion and item.promotion.isValid() %}
                    {% set originalPrice = item.product.price * item.quantity %}
                    {% set discountedPrice = item.discountedPrice * item.quantity %}
                    {% set itemDiscount = originalPrice - discountedPrice %}
                    {% set totalDiscount = totalDiscount + itemDiscount %}
                {% endif %}
            {% endfor %}
            {% set totalWithDiscount = total - totalDiscount %}
            {% set totalWithShipping = totalWithDiscount + shipping %}

            <div class="row g-4">
                <div class="col-lg-8">
                    <div class="d-flex flex-column gap-3">
                        {% for item in cartData %}
                            <div class="cart-line">
                                <div class="row align-items-center g-3">
                                    <div class="col-md-2">
                                        {% if item.product.images|length > 0 %}
                                            <img src="{{ asset('uploads/products/' ~ item.product.images.first.filename) }}" class="img-fluid" alt="{{ item.product.name }}">
                                        {% else %}
                                            <img src="{{ asset('images/placeholder.webp') }}" class="img-fluid" alt="Image non disponible">
                                        {% endif %}
                                    </div>

                                    <div class="col-md-4">
                                        <h5 class="mb-1">{{ item.product.name }}</h5>
                                        <div class="d-flex flex-wrap gap-1">
                                            <span class="badge bg-primary">Taille: {{ item.size ?? 'A choisir' }}</span>
                                            <span class="badge bg-info text-dark">Couleur: {{ item.color ?? 'A choisir' }}</span>
                                            {% if item.size is empty or item.color is empty %}
                                                <a href="{{ path('product_detail', {'id': item.product.id}) }}" class="badge bg-warning text-dark text-decoration-none">Completer</a>
                                            {% endif %}
                                        </div>
                                    </div>

                                    <div class="col-md-2">
                                        {% if item.promotion and item.promotion.isValid() %}
                                            <span class="text-muted text-decoration-line-through small d-block">{{ item.product.price|number_format(2) }} DT</span>
                                            <span class="fw-bold text-success">{{ item.discountedPrice|number_format(2) }} DT</span>
                                            <span class="badge bg-danger d-inline-block mt-1">-{{ item.discount }}%</span>
                                        {% else %}
                                            <span class="fw-bold">{{ item.product.price|number_format(2) }} DT</span>
                                        {% endif %}
                                    </div>

                                    <div class="col-md-2">
                                        <label class="form-label small text-muted mb-1">Quantite</label>
                                        <input type="number" class="form-control form-control-sm text-center" value="{{ item.quantity }}" min="1" onchange="updateQuantity({{ item.key|json_encode|raw }}, this.value)">
                                    </div>

                                    <div class="col-md-2 text-md-end">
                                        {% if item.promotion and item.promotion.isValid() %}
                                            <span class="text-muted text-decoration-line-through small d-block">{{ (item.product.price * item.quantity)|number_format(2) }} DT</span>
                                            <span class="fw-bold text-success">{{ (item.discountedPrice * item.quantity)|number_format(2) }} DT</span>
                                        {% else %}
                                            <span class="fw-bold">{{ (item.product.price * item.quantity)|number_format(2) }} DT</span>
                                        {% endif %}
                                        <form method="POST" action="{{ path('cart_remove', {'key': item.key}) }}" class="d-inline" onsubmit="return confirm('Retirer ce produit du panier ?')">
                                            <input type="hidden" name="_token" value="{{ csrf_token('cart_remove_' ~ item.key) }}">
                                            <button type="submit" class="btn btn-sm btn-outline-danger mt-2" aria-label="Retirer ce produit du panier">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="card summary-card">
                        <div class="card-header">
                            <h5 class="mb-0">Recapitulatif</h5>
                        </div>
                        <div class="card-body">
                            <div class="d-flex justify-content-between mb-2">
                                <span>Sous-total</span>
                                <span>{{ total|number_format(2) }} DT</span>
                            </div>
                            {% if totalDiscount > 0 %}
                                <div class="d-flex justify-content-between mb-2 text-success">
                                    <span>Remise</span>
                                    <span>-{{ totalDiscount|number_format(2) }} DT</span>
                                </div>
                                <div class="d-flex justify-content-between mb-2">
                                    <span>Apres remise</span>
                                    <span>{{ totalWithDiscount|number_format(2) }} DT</span>
                                </div>
                            {% endif %}
                            <div class="d-flex justify-content-between mb-2">
                                <span>Livraison</span>
                                <span>{{ shipping|number_format(2) }} DT</span>
                            </div>
                            <hr>
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <strong>Total</strong>
                                <strong class="summary-total">{{ totalWithShipping|number_format(2) }} DT</strong>
                            </div>

                            {% if totalDiscount > 0 %}
                                <div class="alert alert-success border-0 rounded-3 small">
                                    <i class="fas fa-gift me-1"></i>
                                    Vous economisez <strong>{{ totalDiscount|number_format(2) }} DT</strong>.
                                </div>
                            {% endif %}

                            <div class="d-grid gap-2">
                                <a href="{{ path('checkout') }}" class="btn btn-primary btn-lg">
                                    Commander
                                </a>
                                <a href="{{ path('products') }}" class="btn btn-outline-primary">
                                    Continuer mes achats
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="bc-empty-state text-center py-5 px-3">
                <i class="fas fa-shopping-bag fa-4x text-primary mb-4"></i>
                <h3>Votre panier est vide</h3>
                <p class="text-muted mb-4">Decouvrez la collection et ajoutez vos coups de coeur.</p>
                <a href="{{ path('products') }}" class="btn btn-primary btn-lg">Decouvrir les produits</a>
            </div>
        {% endif %}
    </div>

    <script>
        const cartUpdateToken = {{ csrf_token('cart_update')|json_encode|raw }};

        function updateQuantity(cartKey, quantity) {
            if (quantity < 1) {
                if (!confirm('Retirer ce produit du panier ?')) {
                    window.location.reload();
                    return;
                }
            }

            fetch('{{ path('cart_update') }}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({ cartKey: cartKey, quantity: quantity, _token: cartUpdateToken })
            }).then(function (response) {
                return response.json();
            }).then(function (data) {
                if (data.success) {
                    window.location.reload();
                    return;
                }
                alert(data.message || 'Une erreur est survenue lors de la mise a jour du panier.');
            }).catch(function () {
                alert('Une erreur est survenue lors de la mise a jour du panier.');
            });
        }
    </script>
{% endblock %}
