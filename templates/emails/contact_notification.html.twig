{% set email_title = 'Nouveau message de contact' %}
{% set email_preheader = 'Un nouveau message client a ete envoye depuis le formulaire de contact.' %}
{% set email_badge = 'Contact client' %}
{% set email_action_url = absolute_url(path('admin_contacts')) %}
{% set email_action_label = 'Voir les messages' %}
{% extends 'emails/_layout.html.twig' %}

{% block email_heading %}Nouveau message de contact{% endblock %}

{% block email_body %}
    <p style="margin:0 0 18px; color:#5d4754; font-size:15px; line-height:24px;">
        Un visiteur vient d'envoyer un message depuis le site Bella Couture.
    </p>

    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin:0 0 22px; background-color:#fff7f9; border:1px solid #eadde3; border-radius:14px;">
        <tr>
            <td style="padding:18px; color:#5d4754; font-size:14px; line-height:23px;">
                <strong style="color:#2f2430;">Nom :</strong> {{ contact.name }}<br>
                <strong style="color:#2f2430;">Email :</strong> <a href="mailto:{{ contact.email }}" style="color:#b23a63; text-decoration:none;">{{ contact.email }}</a><br>
                {% if contact.phone %}
                    <strong style="color:#2f2430;">Telephone :</strong> <a href="tel:{{ contact.phone }}" style="color:#b23a63; text-decoration:none;">{{ contact.phone }}</a><br>
                {% endif %}
                <strong style="color:#2f2430;">Date :</strong> {{ contact.createdAt|date('d/m/Y \\a H:i') }}
            </td>
        </tr>
    </table>

    <h2 style="margin:0 0 12px; color:#2f2430; font-size:20px; line-height:26px;">Message</h2>
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="border:1px solid #eadde3; border-radius:12px;">
        <tr>
            <td style="padding:18px; color:#2f2430; font-size:15px; line-height:25px; background-color:#ffffff;">
                {{ contact.message|nl2br }}
            </td>
        </tr>
    </table>
{% endblock %}
