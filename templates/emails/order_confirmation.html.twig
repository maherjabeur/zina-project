{% set email_title = 'Confirmation de votre commande' %}
{% set email_preheader = 'Votre commande ' ~ order.orderNumber ~ ' a bien ete recue par Bella Couture.' %}
{% set email_badge = 'Commande confirmee' %}
{% set email_action_url = absolute_url(path('products')) %}
{% set email_action_label = 'Retour a la boutique' %}
{% extends 'emails/_layout.html.twig' %}

{% block email_heading %}Confirmation de votre commande{% endblock %}

{% block email_body %}
    <p style="margin:0 0 14px; color:#2f2430; font-size:16px; line-height:25px;">
        Bonjour <strong>{{ order.customerName }}</strong>,
    </p>
    <p style="margin:0 0 22px; color:#5d4754; font-size:15px; line-height:24px;">
        Merci pour votre commande. Nous l'avons bien recue et nous vous contacterons pour confirmer les details de livraison.
    </p>

    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin:0 0 22px; background-color:#fff7f9; border:1px solid #eadde3; border-radius:14px;">
        <tr>
            <td style="padding:18px;">
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                    <tr>
                        <td class="stack-column" width="50%" style="padding:0 12px 12px 0; color:#7b717a; font-size:13px; line-height:20px;">
                            Numero de commande<br>
                            <strong style="color:#2f2430; font-size:16px;">{{ order.orderNumber }}</strong>
                        </td>
                        <td class="stack-column" width="50%" style="padding:0 0 12px 12px; color:#7b717a; font-size:13px; line-height:20px;">
                            Date<br>
                            <strong style="color:#2f2430; font-size:16px;">{{ order.createdAt|date('d/m/Y \\a H:i') }}</strong>
                        </td>
                    </tr>
                    <tr>
                        <td class="stack-column" width="50%" style="padding:0 12px 0 0; color:#7b717a; font-size:13px; line-height:20px;">
                            Statut<br>
                            <span style="display:inline-block; margin-top:4px; padding:5px 10px; border-radius:999px; background-color:#b23a63; color:#ffffff; font-size:12px; font-weight:bold;">{{ order.statusLabel }}</span>
                        </td>
                        <td class="stack-column" width="50%" style="padding:0 0 0 12px; color:#7b717a; font-size:13px; line-height:20px;">
                            Total final<br>
                            <strong style="color:#b23a63; font-size:18px;">{{ order.total|number_format(2, ',', ' ') }} DT</strong>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>

    <h2 style="margin:0 0 12px; color:#2f2430; font-size:20px; line-height:26px;">Articles commandes</h2>
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="border:1px solid #eadde3; border-radius:12px; overflow:hidden; margin:0 0 22px;">
        <tr>
            <td style="padding:0;">
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                    <tr>
                        <th align="left" style="padding:11px 12px; background-color:#f7eef2; color:#5d4754; font-size:12px; line-height:16px;">Produit</th>
                        <th align="left" style="padding:11px 8px; background-color:#f7eef2; color:#5d4754; font-size:12px; line-height:16px;">Taille</th>
                        <th align="left" style="padding:11px 8px; background-color:#f7eef2; color:#5d4754; font-size:12px; line-height:16px;">Couleur</th>
                        <th align="center" style="padding:11px 8px; background-color:#f7eef2; color:#5d4754; font-size:12px; line-height:16px;">Qt.</th>
                        <th align="right" style="padding:11px 12px; background-color:#f7eef2; color:#5d4754; font-size:12px; line-height:16px;">Total</th>
                    </tr>
                    {% for item in order.items %}
                        <tr>
                            <td style="padding:12px; border-top:1px solid #eadde3; color:#2f2430; font-size:13px; line-height:19px; font-weight:bold;">{{ item.product.name }}</td>
                            <td style="padding:12px 8px; border-top:1px solid #eadde3; color:#5d4754; font-size:13px; line-height:19px;">{{ item.size ?? 'Non specifie' }}</td>
                            <td style="padding:12px 8px; border-top:1px solid #eadde3; color:#5d4754; font-size:13px; line-height:19px;">{{ item.color ?? 'Non specifie' }}</td>
                            <td align="center" style="padding:12px 8px; border-top:1px solid #eadde3; color:#5d4754; font-size:13px; line-height:19px;">{{ item.quantity }}</td>
                            <td align="right" style="padding:12px; border-top:1px solid #eadde3; color:#2f2430; font-size:13px; line-height:19px; font-weight:bold;">{{ item.total|number_format(2, ',', ' ') }} DT</td>
                        </tr>
                    {% endfor %}
                </table>
            </td>
        </tr>
    </table>

    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="margin:0 0 22px;">
        <tr>
            <td class="stack-column" width="50%" valign="top" style="padding:0 10px 0 0;">
                <h2 style="margin:0 0 10px; color:#2f2430; font-size:18px; line-height:24px;">Livraison</h2>
                <p style="margin:0; color:#5d4754; font-size:14px; line-height:22px;">
                    <strong>{{ order.customerName }}</strong><br>
                    {% if order.customerPhone %}{{ order.customerPhone }}<br>{% endif %}
                    {% if order.shippingAddress %}{{ order.shippingAddress|nl2br }}{% endif %}
                </p>
            </td>
            <td class="stack-column" width="50%" valign="top" style="padding:0 0 0 10px;">
                <h2 style="margin:0 0 10px; color:#2f2430; font-size:18px; line-height:24px;">Recapitulatif</h2>
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                    <tr>
                        <td style="padding:4px 0; color:#7b717a; font-size:14px;">Sous-total</td>
                        <td align="right" style="padding:4px 0; color:#2f2430; font-size:14px;">{{ order.itemsTotal|number_format(2, ',', ' ') }} DT</td>
                    </tr>
                    {% if order.discount and order.discount > 0 %}
                        <tr>
                            <td style="padding:4px 0; color:#7b717a; font-size:14px;">Remise</td>
                            <td align="right" style="padding:4px 0; color:#2f8f72; font-size:14px;">-{{ order.discount|number_format(2, ',', ' ') }} DT</td>
                        </tr>
                    {% endif %}
                    <tr>
                        <td style="padding:4px 0; color:#7b717a; font-size:14px;">Livraison</td>
                        <td align="right" style="padding:4px 0; color:#2f2430; font-size:14px;">{{ (order.shippingFee ?? 0)|number_format(2, ',', ' ') }} DT</td>
                    </tr>
                    <tr>
                        <td style="padding:10px 0 0; border-top:1px solid #eadde3; color:#2f2430; font-size:15px; font-weight:bold;">Total</td>
                        <td align="right" style="padding:10px 0 0; border-top:1px solid #eadde3; color:#b23a63; font-size:17px; font-weight:bold;">{{ order.total|number_format(2, ',', ' ') }} DT</td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>

    <p style="margin:0; color:#5d4754; font-size:14px; line-height:23px;">
        Nous vous remercions pour votre confiance. Pour toute question, repondez simplement a cet email ou contactez-nous par telephone.
    </p>
{% endblock %}
