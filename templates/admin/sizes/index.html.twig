
{% extends 'base.html.twig' %}

{% block title %}Gestion des tailles - Admin{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        {% include 'admin/_sidebar.html.twig' %}

<!-- Main content -->
        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">Gestion des tailles</h1>
                <a href="{{ path('admin_size_new') }}" class="btn btn-primary">
                    <i class="fas fa-plus"></i> Nouvelle taille
                </a>
            </div>

            <!-- Statistiques -->
            <div class="row mb-4">
                <div class="col-md-3">
                    <div class="card text-white bg-primary">
                        <div class="card-body">
                            <h6 class="card-title">Total tailles</h6>
                            <h4 class="card-text">{{ sizes|length }}</h4>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card text-white bg-success">
                        <div class="card-body">
                            <h6 class="card-title">Actives</h6>
                            <h4 class="card-text">{{ sizes|filter(s => s[0].isActive)|length }}</h4>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card text-white bg-info">
                        <div class="card-body">
                            <h6 class="card-title">Total produits</h6>
                            <h4 class="card-text">{{ sizes|reduce((total, s) => total + s.productCount, 0) }}</h4>
                        </div>
                    </div>
                </div>
            </div>

        

            <!-- Liste des tailles -->
            <div class="card">
                <div class="card-body">
                    {% if sizes|length > 0 %}
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead>
                                    <tr>
                                        <th>Nom</th>
                                        <th>Code</th>
                                        <th>Type</th>
                                        <th>Produits</th>
                                        <th>Position</th>
                                        <th>Statut</th>
                                        <th>Créée le</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for sizeData in sizes %}
                                        {% set size = sizeData[0] %}
                                        {% set productCount = sizeData.productCount %}
                                        <tr>
                                            <td>
                                                <strong>{{ size.name }}</strong>
                                            </td>
                                            <td>
                                                <code>{{ size.code }}</code>
                                            </td>
                                            <td>
                                                <span class="badge bg-{{ 
                                                    size.type == 'clothing' ? 'primary' : 
                                                    (size.type == 'shoes' ? 'success' : 'info') 
                                                }}">
                                                    {{ size.type }}
                                                </span>
                                            </td>
                                            <td>
                                                <span class="badge bg-primary">{{ productCount }}</span>
                                            </td>
                                            <td>
                                                <span class="badge bg-secondary">{{ size.position }}</span>
                                            </td>
                                            <td>
                                                {% if size.isActive %}
                                                    <span class="badge bg-success">Active</span>
                                                {% else %}
                                                    <span class="badge bg-secondary">Inactive</span>
                                                {% endif %}
                                            </td>
                                            <td>
                                                <small class="text-muted">{{ size.createdAt|date('d/m/Y') }}</small>
                                            </td>
                                            <td>
                                                <div class="btn-group btn-group-sm">
                                                    <a href="{{ path('admin_size_edit', {'id': size.id}) }}" 
                                                       class="btn btn-outline-secondary" title="Modifier">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <form method="POST" action="{{ path('admin_size_toggle', {'id': size.id}) }}" 
                                                          class="d-inline">
                                                        <button type="submit" class="btn btn-{{ size.isActive ? 'warning' : 'success' }}" 
                                                                title="{{ size.isActive ? 'Désactiver' : 'Activer' }}">
                                                            <i class="fas fa-{{ size.isActive ? 'pause' : 'play' }}"></i>
                                                        </button>
                                                    </form>
                                                    <form method="POST" action="{{ path('admin_size_delete', {'id': size.id}) }}" 
                                                          onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette taille ?')"
                                                          class="d-inline">
                                                        <button type="submit" class="btn btn-outline-danger" title="Supprimer">
                                                            <i class="fas fa-trash"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% else %}
                        <div class="text-center py-5">
                            <i class="fas fa-ruler fa-3x text-muted mb-3"></i>
                            <h3>Aucune taille</h3>
                            <p class="text-muted">Commencez par créer votre première taille.</p>
                            <a href="{{ path('admin_size_new') }}" class="btn btn-primary">
                                <i class="fas fa-plus"></i> Créer une taille
                            </a>
                        </div>
                    {% endif %}
                </div>
            </div>
        </main>
    </div>
</div>
{% endblock %}