
{% extends 'base.html.twig' %}

{% block title %}Modifier {{ size.name }} - Admin{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        {% include 'admin/_sidebar.html.twig' %}

<!-- Main content -->
        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">Modifier "{{ size.name }}"</h1>
                <div>
                    <a href="{{ path('admin_sizes') }}" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left"></i> Retour
                    </a>
                </div>
            </div>

            <div class="row">
                <div class="col-md-8">
                    <div class="card">
                        <div class="card-body">
                            {{ form_start(form) }}
                            
                            <div class="row">
                                <div class="col-md-6">
                                    {{ form_row(form.name, {
                                        'attr': {'class': 'form-control'},
                                        'label': 'Nom de la taille *'
                                    }) }}
                                </div>
                                <div class="col-md-6">
                                    {{ form_row(form.nameAr, {
                                        'attr': {'class': 'form-control', 'dir': 'rtl'},
                                        'label': 'Nom de la taille (AR) *'
                                    }) }}
                                </div>
                                <div class="col-md-6">
                                    {{ form_row(form.code, {
                                        'attr': {'class': 'form-control'},
                                        'label': 'Code *'
                                    }) }}
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    {{ form_row(form.type, {
                                        'attr': {'class': 'form-select'},
                                        'label': 'Type de taille *'
                                    }) }}
                                </div>
                                <div class="col-md-6">
                                    {{ form_row(form.position, {
                                        'attr': {'class': 'form-control'},
                                        'label': 'Position'
                                    }) }}
                                </div>
                            </div>

                            <div class="form-check mb-4">
                                {{ form_widget(form.isActive, {
                                    'attr': {'class': 'form-check-input'}
                                }) }}
                                {{ form_label(form.isActive, 'Taille active', {
                                    'label_attr': {'class': 'form-check-label'}
                                }) }}
                            </div>

                            <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-save"></i> Enregistrer
                                </button>
                                <a href="{{ path('admin_sizes') }}" class="btn btn-outline-secondary">
                                    Annuler
                                </a>
                            </div>

                            {{ form_end(form) }}
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <!-- Informations -->
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="mb-0">Informations</h5>
                        </div>
                        <div class="card-body">
                            <p><strong>Créée le:</strong> {{ size.createdAt|date('d/m/Y à H:i') }}</p>
                            <p><strong>Modifiée le:</strong> {{ size.updatedAt|date('d/m/Y à H:i') }}</p>
                            <p><strong>Produits:</strong> {{ size.products|length }} produit(s)</p>
                        </div>
                    </div>

                    <!-- Actions -->
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">Actions</h5>
                        </div>
                        <div class="card-body">
                            <div class="d-grid gap-2">
                                <form method="POST" action="{{ path('admin_size_toggle', {'id': size.id}) }}" class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('admin_size_toggle_' ~ size.id) }}">
                                    <button type="submit" class="btn btn-{{ size.isActive ? 'warning' : 'success' }} w-100">
                                        <i class="fas fa-{{ size.isActive ? 'pause' : 'play' }}"></i>
                                        {{ size.isActive ? 'Désactiver' : 'Activer' }}
                                    </button>
                                </form>

                                {% if size.products|length == 0 %}
                                    <form method="POST" action="{{ path('admin_size_delete', {'id': size.id}) }}" 
                                          onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette taille ?')"
                                          class="d-inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('admin_size_delete_' ~ size.id) }}">
                                        <button type="submit" class="btn btn-outline-danger w-100">
                                            <i class="fas fa-trash"></i> Supprimer
                                        </button>
                                    </form>
                                {% else %}
                                    <button class="btn btn-outline-secondary w-100" disabled title="Impossible de supprimer - taille utilisée">
                                        <i class="fas fa-trash"></i> Supprimer (bloqué)
                                    </button>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>
{% endblock %}
