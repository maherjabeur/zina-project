{% extends 'base.html.twig' %}

{% block title %}Messages de contact - Admin{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        {% include 'admin/_sidebar.html.twig' %}

        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">Messages de contact</h1>
                <span class="badge bg-{{ unreadCount > 0 ? 'danger' : 'secondary' }}">
                    {{ unreadCount }} non lu(s)
                </span>
            </div>

            <div class="card">
                <div class="card-body">
                    {% if contacts|length > 0 %}
                        <div class="table-responsive">
                            <table class="table table-striped table-hover align-middle">
                                <thead>
                                    <tr>
                                        <th>Nom</th>
                                        <th>Email</th>
                                        <th>Telephone</th>
                                        <th>Message</th>
                                        <th>Statut</th>
                                        <th>Date</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for contact in contacts %}
                                        <tr>
                                            <td><strong>{{ contact.name }}</strong></td>
                                            <td><a href="mailto:{{ contact.email }}">{{ contact.email }}</a></td>
                                            <td>{{ contact.phone ?: '-' }}</td>
                                            <td>{{ contact.message|striptags|slice(0, 70) }}{% if contact.message|striptags|length > 70 %}...{% endif %}</td>
                                            <td>
                                                {% if contact.isRead %}
                                                    <span class="badge bg-secondary">Lu</span>
                                                {% else %}
                                                    <span class="badge bg-danger">Non lu</span>
                                                {% endif %}
                                            </td>
                                            <td>{{ contact.createdAt|date('d/m/Y H:i') }}</td>
                                            <td>
                                                <div class="btn-group btn-group-sm">
                                                    <a href="{{ path('admin_contact_show', {'id': contact.id}) }}" class="btn btn-outline-primary" title="Voir">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                    <form method="POST" action="{{ path('admin_contact_delete', {'id': contact.id}) }}" class="d-inline" onsubmit="return confirm('Supprimer ce message ?')">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('admin_contact_delete_' ~ contact.id) }}">
                                                        <button type="submit" class="btn btn-outline-danger" title="Supprimer">
                                                            <i class="fas fa-trash"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% else %}
                        <div class="text-center py-5">
                            <i class="fas fa-envelope-open-text fa-3x text-muted mb-3"></i>
                            <h3>Aucun message</h3>
                            <p class="text-muted mb-0">Les messages envoyes depuis le formulaire de contact apparaitront ici.</p>
                        </div>
                    {% endif %}
                </div>
            </div>
        </main>
    </div>
</div>
{% endblock %}
