{% extends 'base.html.twig' %}

{% block title %}Message de {{ contact.name }} - Admin{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        {% include 'admin/_sidebar.html.twig' %}

        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">Message de contact</h1>
                <a href="{{ path('admin_contacts') }}" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left"></i> Retour
                </a>
            </div>

            <div class="row g-4">
                <div class="col-lg-8">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">Message</h5>
                        </div>
                        <div class="card-body">
                            <p class="mb-0" style="white-space: pre-wrap;">{{ contact.message }}</p>
                        </div>
                    </div>
                </div>

                <div class="col-lg-4">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">Coordonnees</h5>
                        </div>
                        <div class="card-body">
                            <p><strong>Nom:</strong> {{ contact.name }}</p>
                            <p><strong>Email:</strong> <a href="mailto:{{ contact.email }}">{{ contact.email }}</a></p>
                            <p><strong>Telephone:</strong> {{ contact.phone ?: 'Non renseigne' }}</p>
                            <p><strong>Date:</strong> {{ contact.createdAt|date('d/m/Y H:i') }}</p>

                            <form method="POST" action="{{ path('admin_contact_delete', {'id': contact.id}) }}" onsubmit="return confirm('Supprimer ce message ?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('admin_contact_delete_' ~ contact.id) }}">
                                <button type="submit" class="btn btn-outline-danger w-100">
                                    <i class="fas fa-trash"></i> Supprimer
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>
{% endblock %}
