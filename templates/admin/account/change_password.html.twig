{% extends 'base.html.twig' %}

{% set is_ar = app.request.locale == 'ar' %}
{% set is_admin_route = app.request.attributes.get('_route') starts with 'admin_' %}
{% set password_route = is_admin_route ? 'admin_change_password' : 'profile_change_password' %}
{% set cancel_route = is_admin_route ? 'admin_dashboard' : 'home' %}

{% block title %}{{ is_ar ? 'تغيير كلمة المرور' : 'Changer le mot de passe' }} - Bella Couture{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        {% if is_admin_route %}
            {% include 'admin/_sidebar.html.twig' %}
        {% endif %}

        <main class="{{ is_admin_route ? 'col-md-9 ms-sm-auto col-lg-10' : 'col-12' }} px-md-4">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">{{ is_ar ? 'تغيير كلمة المرور' : 'Changer le mot de passe' }}</h1>
                <a href="{{ path(cancel_route) }}" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-1"></i> {{ is_ar ? 'رجوع' : 'Retour' }}
                </a>
            </div>

            <div class="row">
                <div class="col-lg-7 col-xl-6">
                    <div class="card">
                        <div class="card-body">
                            <form method="post" action="{{ path(password_route) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('change_password') }}">

                                <div class="mb-3">
                                    <label for="currentPassword" class="form-label">{{ is_ar ? 'كلمة المرور الحالية' : 'Mot de passe actuel' }}</label>
                                    <input type="password" name="current_password" id="currentPassword" class="form-control" autocomplete="current-password" required>
                                </div>

                                <div class="mb-3">
                                    <label for="newPassword" class="form-label">{{ is_ar ? 'كلمة المرور الجديدة' : 'Nouveau mot de passe' }}</label>
                                    <input type="password" name="new_password" id="newPassword" class="form-control" autocomplete="new-password" minlength="8" required>
                                </div>

                                <div class="mb-4">
                                    <label for="confirmPassword" class="form-label">{{ is_ar ? 'تأكيد كلمة المرور' : 'Confirmer le mot de passe' }}</label>
                                    <input type="password" name="confirm_password" id="confirmPassword" class="form-control" autocomplete="new-password" minlength="8" required>
                                </div>

                                <div class="d-flex gap-2">
                                    <button type="submit" class="btn btn-primary">
                                        <i class="fas fa-key me-1"></i> {{ is_ar ? 'تحديث كلمة المرور' : 'Mettre a jour le mot de passe' }}
                                    </button>
                                    <a href="{{ path(cancel_route) }}" class="btn btn-outline-secondary">
                                        {{ is_ar ? 'إلغاء' : 'Annuler' }}
                                    </a>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>
{% endblock %}
