{% extends 'base.html.twig' %}

{% block title %}Modifier {{ product.name }} - Admin{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href="{{ asset('css/select2.min.css') }}" rel="stylesheet">
{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        {% include 'admin/_sidebar.html.twig' %}

<!-- Main content -->
        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">Modifier "{{ product.name }}"</h1>
                <div>
                    <a href="{{ path('admin_products') }}" class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left"></i> Retour
                    </a>
                </div>
            </div>

            <div class="row">
                <div class="col-md-8">
                    <div class="card">
                        <div class="card-body">
                            {{ form_start(form) }}
                            
                            <div class="row">
                                <div class="col-md-6">
                                    {{ form_row(form.name, {
                                        'attr': {'class': 'form-control'},
                                        'label': 'Nom du produit'
                                    }) }}
                                </div>
                                <div class="col-md-6">
                                    {{ form_row(form.price, {
                                        'attr': {'class': 'form-control', 'step': '0.01'},
                                        'label': 'Prix (Dt)'
                                    }) }}
                                </div>
                            </div>

                            <div class="row">
                         <div class="col-md-12">
    {{ form_row(form.sizes, {
        'attr': {'class': 'form-select product-size-select', 'data-placeholder': 'Rechercher et choisir plusieurs tailles'},
        'label': 'Tailles disponibles'
    }) }}
    <div class="d-flex flex-wrap gap-2 mt-2 mb-3">
        <button type="button" class="btn btn-sm btn-outline-primary js-select-all-sizes">
            <i class="fas fa-check-double me-1"></i> Tout selectionner
        </button>
        <button type="button" class="btn btn-sm btn-outline-secondary js-clear-sizes">
            <i class="fas fa-xmark me-1"></i> Vider
        </button>
    </div>
</div>
                                <div class="col-md-4">
                                    {{ form_row(form.color, {
                                        'attr': {'class': 'form-control', 'rows': 2, 'placeholder': 'Noir, Blanc, Rose poudre'},
                                        'label': 'Couleurs disponibles'
                                    }) }}
                                </div>
                                <div class="col-md-4">
                                    {{ form_row(form.category, {
                                        'attr': {'class': 'form-control'},
                                        'label': 'Catégorie'
                                    }) }}
                                </div>
                            </div>

                            {{ form_row(form.quantity, {
                                'attr': {'class': 'form-control'},
                                'label': 'Quantité en stock'
                            }) }}

                            {{ form_row(form.description, {
                                'attr': {'class': 'form-control', 'rows': 4},
                                'label': 'Description'
                            }) }}

                            <div class="form-check mb-3">
                                {{ form_widget(form.isActive, {
                                    'attr': {'class': 'form-check-input'}
                                }) }}
                                {{ form_label(form.isActive, 'Produit actif', {
                                    'label_attr': {'class': 'form-check-label'}
                                }) }}
                            </div>

                            <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-save"></i> Enregistrer les modifications
                                </button>
                                <a href="{{ path('admin_products') }}" class="btn btn-outline-secondary">
                                    Annuler
                                </a>
                            </div>

                            {{ form_end(form) }}
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <!-- Informations du produit -->
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="mb-0">Informations du produit</h5>
                        </div>
                        <div class="card-body">
                            <p><strong>Créé le:</strong> {{ product.createdAt|date('d/m/Y à H:i') }}</p>
                            {% if product.images|length > 0 %}
                                <p><strong>Images:</strong> {{ product.images|length }}</p>
                            {% endif %}
                            <p><strong>Référence:</strong> #{{ product.id }}</p>
                        </div>
                    </div>

                    <!-- Actions rapides -->
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">Actions</h5>
                        </div>
                        <div class="card-body">
    <div class="d-grid gap-2">
        <a href="{{ path('product_detail', {'id': product.id}) }}" 
           class="btn btn-outline-primary" target="_blank">
            <i class="fas fa-eye"></i> Voir en boutique
        </a>
        
        <form method="POST" action="{{ path('admin_product_toggle', {'id': product.id}) }}" class="d-inline">
            <button type="submit" class="btn btn-{{ product.isActive ? 'warning' : 'success' }} w-100">
                <i class="fas fa-{{ product.isActive ? 'pause' : 'play' }}"></i>
                {{ product.isActive ? 'Désactiver' : 'Activer' }}
            </button>
        </form>

        <form method="POST" action="{{ path('admin_product_delete', {'id': product.id}) }}" 
              onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce produit ?')"
              class="d-inline">
            <button type="submit" class="btn btn-outline-danger w-100">
                <i class="fas fa-trash"></i> Supprimer
            </button>
        </form>
    </div>
</div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/select2.min.js') }}"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (!window.jQuery) {
                return;
            }

            const $ = window.jQuery;
            const $sizeSelect = $('.product-size-select');

            if (!$sizeSelect.length) {
                return;
            }

            function getSelectableValues($select) {
                return $select.find('option').filter(function () {
                    return this.value !== '' && !this.disabled;
                }).map(function () {
                    return this.value;
                }).get();
            }

            function updateSizeSelect($select, values) {
                $select.val(values);
                $select.trigger('change');
                if ($.fn.select2) {
                    $select.trigger('change.select2');
                }
            }

            if ($.fn.select2) {
                $sizeSelect.each(function () {
                    const $select = $(this);
                    if ($select.data('select2')) {
                        $select.select2('destroy');
                    }

                    $select.select2({
                        width: '100%',
                        closeOnSelect: false,
                        placeholder: $select.data('placeholder') || 'Rechercher et choisir plusieurs tailles',
                        allowClear: true,
                        language: {
                            noResults: function () { return 'Aucune taille trouvee'; },
                            searching: function () { return 'Recherche...'; },
                            removeAllItems: function () { return 'Vider la selection'; },
                            removeItem: function () { return 'Retirer'; },
                            search: function () { return 'Rechercher'; }
                        }
                    });
                });
            }

            $('.js-select-all-sizes').on('click', function () {
                const $select = $(this).closest('form').find('.product-size-select');
                updateSizeSelect($select, getSelectableValues($select));
            });

            $('.js-clear-sizes').on('click', function () {
                const $select = $(this).closest('form').find('.product-size-select');
                updateSizeSelect($select, []);
            });
        });
    </script>
{% endblock %}
