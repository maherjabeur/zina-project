{% extends 'base.html.twig' %}

{% block title %}Nouveau produit - Admin{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        {% include 'admin/_sidebar.html.twig' %}

<!-- Main content -->
        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <h1 class="h2">Nouveau produit</h1>
                <a href="{{ path('admin_products') }}" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left"></i> Retour
                </a>
            </div>

            <div class="row">
                <div class="col-md-8">
                    <div class="card">
                        <div class="card-body">
                            {{ form_start(form) }}
                            
                            <div class="row">
                                <div class="col-md-6">
                                    {{ form_row(form.name, {
                                        'attr': {'class': 'form-control'},
                                        'label': 'Nom du produit (FR)'
                                    }) }}
                                </div>
                                <div class="col-md-6">
                                    {{ form_row(form.nameAr, {
                                        'attr': {'class': 'form-control', 'dir': 'rtl'},
                                        'label': 'Nom du produit (AR)'
                                    }) }}
                                </div>
                                <div class="col-md-6">
                                    {{ form_row(form.price, {
                                        'attr': {'class': 'form-control', 'step': '0.01'},
                                        'label': 'Prix (Dt)'
                                    }) }}
                                </div>
                            </div>

                            <div class="row">
                              <div class="col-md-12">
    {{ form_row(form.sizes, {
        'attr': {'class': 'form-select product-size-select', 'data-placeholder': app.request.locale == 'ar' ? 'ابحث واختر عدة مقاسات' : 'Rechercher et choisir plusieurs tailles'},
        'label': 'Tailles disponibles'
    }) }}
    <div class="d-flex flex-wrap gap-2 mt-2 mb-3">
        <button type="button" class="btn btn-sm btn-outline-primary js-select-all-sizes">
            <i class="fas fa-check-double me-1"></i> Tout selectionner
        </button>
        <button type="button" class="btn btn-sm btn-outline-secondary js-clear-sizes">
            <i class="fas fa-xmark me-1"></i> Vider
        </button>
    </div>
</div>
                                <div class="col-md-4">
                                    {{ form_row(form.color, {
                                        'attr': {'class': 'form-control', 'rows': 2, 'placeholder': 'Noir, Blanc, Rose poudre'},
                                        'label': 'Couleurs disponibles (FR)'
                                    }) }}
                                </div>
                                <div class="col-md-4">
                                    {{ form_row(form.colorAr, {
                                        'attr': {'class': 'form-control', 'rows': 2, 'placeholder': 'أسود، أبيض، وردي باهت', 'dir': 'rtl'},
                                        'label': 'Couleurs disponibles (AR)'
                                    }) }}
                                </div>
                                <div class="col-md-4">
                                    {{ form_row(form.category, {
                                        'attr': {'class': 'form-control'},
                                        'label': 'Catégorie'
                                    }) }}
                                </div>
                            </div>

                            {{ form_row(form.quantity, {
                                'attr': {'class': 'form-control'},
                                'label': 'Quantité en stock'
                            }) }}

                            {{ form_row(form.description, {
                                'attr': {'class': 'form-control', 'rows': 4},
                                'label': 'Description (FR)'
                            }) }}

                            {{ form_row(form.descriptionAr, {
                                'attr': {'class': 'form-control', 'rows': 4, 'dir': 'rtl'},
                                'label': 'Description (AR)'
                            }) }}

                            <div class="form-check mb-3">
                                {{ form_widget(form.isActive, {
                                    'attr': {'class': 'form-check-input'}
                                }) }}
                                {{ form_label(form.isActive, 'Produit actif', {
                                    'label_attr': {'class': 'form-check-label'}
                                }) }}
                            </div>

                            <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-save"></i> Créer le produit
                                </button>
                                <a href="{{ path('admin_products') }}" class="btn btn-outline-secondary">
                                    Annuler
                                </a>
                            </div>

                            {{ form_end(form) }}
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0">Informations</h5>
                        </div>
                        <div class="card-body">
                            <p class="small text-muted">
                                <i class="fas fa-info-circle"></i>
                                Les produits créés seront immédiatement visibles dans la boutique 
                                s'ils sont marqués comme "actifs".
                            </p>
                            <hr>
                            <h6>Tailles disponibles:</h6>
                            <ul class="small">
                                <li>XS, S, M, L, XL, XXL</li>
                                <li>34, 36, 38, 40, 42, 44</li>
                            </ul>
                            <h6>Couleurs:</h6>
                            <p class="small text-muted mb-0">Vous pouvez saisir plusieurs couleurs separees par des virgules.</p>
                            <h6>Catégories suggérées:</h6>
                            <ul class="small">
                                <li>Robe, Jupe, Pantalon, Haut</li>
                                <li>Veste, Chemisier, Jean, Short</li>
                                <li>Accessoire, Maillot, Sous-vêtement</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {% include 'admin/products/_size_select2.html.twig' %}
{% endblock %}
