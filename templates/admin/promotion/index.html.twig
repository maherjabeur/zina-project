{% extends 'base.html.twig' %}

{% block title %}Gestion des promotions - Admin{% endblock %}

{% block body %}
    <div class="container-fluid">
        <div class="row">
        {% include 'admin/_sidebar.html.twig' %}

<!-- Main content -->
            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
                <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                    <h1 class="h2">Gestion des promotions</h1>
                    <a href="{{ path('admin_promotion_new') }}" class="btn btn-primary">
                        <i class="fas fa-plus"></i> Nouvelle promotion
                    </a>
                </div>

                <!-- Statistiques -->
                <div class="row mb-4">
                    <div class="col-md-3">
                        <div class="card bg-primary text-white">
                            <div class="card-body">
                                <div class="d-flex justify-content-between">
                                    <div>
                                        <h4>{{ promotions|length }}</h4>
                                        <p class="mb-0">Promotions actives</p>
                                    </div>
                                    <div class="align-self-center">
                                        <i class="fas fa-gift fa-2x"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Liste des promotions -->
                <div class="card">
                    <div class="card-body">
                        {% if promotions|length > 0 %}
                            <div class="table-responsive">
                                <table class="table table-striped table-hover">
                                    <thead>
                                        <tr>
                                            <th>Nom</th>
                                            <th>Description</th>
                                            <th>Réduction</th>
                                            <th>Produit</th>
                                            <th>Prix Original</th>
                                            <th>Prix Promo</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for promotion in promotions %}
                                            <tr>
                                                <td>
                                                    <strong>{{ promotion|localized('title') }}</strong>
                                                </td>
                                                <td>
                                                    <small class="text-muted">{{ promotion|localized('description')|slice(0, 50) }}{% if promotion|localized('description')|length > 50 %}...{% endif %}</small>
                                                </td>
                                                <td>
                                                    <span class="badge bg-danger fs-6">{{ promotion.discount }}%</span>
                                                </td>
                                                <td>
                                                    <div class="d-flex align-items-center">
                                                        {% if promotion.product.images|length > 0 %}
                                                            <img src="{{ asset('uploads/products/' ~ promotion.product.images.first.filename) }}" 
                                                                 class="img-thumbnail me-2" 
                                                                 alt="{{ promotion.product.name }}" 
                                                                 style="width: 40px; height: 40px; object-fit: cover;"
                                                                 onerror="this.onerror=null; this.src='{{ asset('images/placeholder.webp') }}';">
                                                        {% endif %}
                                                        <span>{{ promotion.product|localized('name') }}</span>
                                                    </div>
                                                </td>
                                                <td>
                                                    <span class="text-muted text-decoration-line-through">
                                                        {{ promotion.product.price }} Dt
                                                    </span>
                                                </td>
                                                <td>
                                                    <span class="text-success fw-bold">
                                                        {{ (promotion.product.price * (1 - promotion.discount / 100))|number_format(2) }} Dt
                                                    </span>
                                                </td>
                                                <td>
                                                    <div class="btn-group btn-group-sm">
                                                        <a href="{{ path('product_detail', {'id': promotion.product.id}) }}" 
                                                           class="btn btn-outline-primary" 
                                                           title="Voir en boutique" 
                                                           target="_blank">
                                                            <i class="fas fa-eye"></i>
                                                        </a>
                                                        <a href="{{ path('admin_promotion_edit', {'id': promotion.id}) }}" 
                                                           class="btn btn-outline-warning" 
                                                           title="Modifier">
                                                            <i class="fas fa-edit"></i>
                                                        </a>
                                                        <form method="POST" 
                                                              action="{{ path('admin_promotion_delete', {'id': promotion.id}) }}" 
                                                              class="d-inline" 
                                                              onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette promotion ?')">
                                                            <input type="hidden" name="_token" value="{{ csrf_token('admin_promotion_delete_' ~ promotion.id) }}">
                                                            <button type="submit" 
                                                                    class="btn btn-outline-danger" 
                                                                    title="Supprimer">
                                                                <i class="fas fa-trash"></i>
                                                            </button>
                                                        </form>
                                                    </div>
                                                </td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        {% else %}
                            <div class="text-center py-5">
                                <i class="fas fa-gift fa-3x text-muted mb-3"></i>
                                <h3>Aucune promotion</h3>
                                <p class="text-muted">
                                    Créez votre première promotion pour attirer plus de clients.
                                </p>
                                <a href="{{ path('admin_promotion_new') }}" class="btn btn-primary">
                                    <i class="fas fa-plus"></i>
                                    Créer une promotion
                                </a>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </main>
        </div>
    </div>
{% endblock %}
