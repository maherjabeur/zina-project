{% extends 'base.html.twig' %}

{% block title %}Parametres & SEO - Administration{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        {% include 'admin/_sidebar.html.twig' %}

        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                <div>
                    <span class="admin-kicker">Configuration</span>
                    <h1 class="h2 mb-0">Parametres boutique & SEO</h1>
                </div>
                <a href="{{ path('home') }}" class="btn btn-outline-primary btn-sm" target="_blank">
                    <i class="fas fa-external-link-alt me-1"></i> Voir la boutique
                </a>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="card stat-card h-100">
                        <div class="card-body">
                            <span class="text-muted small">Frais actuels</span>
                            <h4 class="mb-0">{{ form.vars.value.shippingFee|default(0) }} DT</h4>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card stat-card h-100">
                        <div class="card-body">
                            <span class="text-muted small">Indexation</span>
                            <h4 class="mb-0">
                                {{ form.vars.value.seoIndexingEnabled ? 'Active' : 'Bloquee' }}
                            </h4>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card stat-card h-100">
                        <div class="card-body">
                            <span class="text-muted small">Image sociale</span>
                            <h4 class="mb-0 text-truncate">{{ form.vars.value.seoImage|default('logo/logo.webp') }}</h4>
                        </div>
                    </div>
                </div>
            </div>

            {{ form_start(form) }}
                <div class="row g-4 align-items-start">
                    <div class="col-xl-8">
                        <div class="card mb-4">
                            <div class="card-header">
                                <h5 class="mb-0"><i class="fas fa-truck me-2"></i> Livraison</h5>
                            </div>
                            <div class="card-body">
                                <div class="row g-3 align-items-end">
                                    <div class="col-md-8">
                                        {{ form_label(form.shippingFee, 'Frais de livraison (DT)', {'label_attr': {'class': 'form-label fw-bold'}}) }}
                                        <div class="input-group">
                                            {{ form_widget(form.shippingFee, {
                                                'attr': {
                                                    'class': 'form-control form-control-lg',
                                                    'min': '0',
                                                    'step': '0.5',
                                                    'placeholder': 'Ex: 7.000'
                                                }
                                            }) }}
                                            <span class="input-group-text">DT</span>
                                        </div>
                                        <div class="form-text">Ces frais sont ajoutes au total de chaque commande.</div>
                                        {{ form_errors(form.shippingFee) }}
                                    </div>
                                    <div class="col-md-4">
                                        <div class="d-grid gap-2">
                                            <button type="button" class="btn btn-outline-primary btn-sm" data-shipping-fee="5">5.000 DT</button>
                                            <button type="button" class="btn btn-outline-primary btn-sm" data-shipping-fee="7">7.000 DT</button>
                                            <button type="button" class="btn btn-outline-primary btn-sm" data-shipping-fee="10">10.000 DT</button>
                                            <button type="button" class="btn btn-outline-secondary btn-sm" data-shipping-fee="0">Gratuit</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="card mb-4">
                            <div class="card-header">
                                <h5 class="mb-0"><i class="fas fa-magnifying-glass-chart me-2"></i> Referencement naturel</h5>
                            </div>
                            <div class="card-body">
                                <div class="mb-3">
                                    {{ form_row(form.seoTitle) }}
                                    <div class="form-text">Idealement entre 50 et 60 caracteres.</div>
                                </div>
                                <div class="mb-3">
                                    {{ form_row(form.seoTitleAr) }}
                                    <div class="form-text">Version arabe utilisee quand la langue du site est arabe.</div>
                                </div>
                                <div class="mb-3">
                                    {{ form_row(form.seoDescription) }}
                                    <div class="form-text">Description recommandee: environ 150 a 160 caracteres.</div>
                                </div>
                                <div class="mb-3">
                                    {{ form_row(form.seoDescriptionAr) }}
                                    <div class="form-text">Description arabe recommandee pour le referencement.</div>
                                </div>
                                <div class="mb-3">
                                    {{ form_row(form.seoKeywords) }}
                                </div>
                                <div class="mb-3">
                                    {{ form_row(form.seoKeywordsAr) }}
                                </div>
                                <div class="row g-3">
                                    <div class="col-md-7">
                                        {{ form_row(form.seoImage) }}
                                        <div class="form-text">Chemin public comme <code>logo/logo.webp</code> ou URL complete.</div>
                                    </div>
                                    <div class="col-md-5">
                                        {{ form_row(form.seoAuthor) }}
                                    </div>
                                </div>
                                <div class="mt-3">
                                    {{ form_row(form.seoIndexingEnabled) }}
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap mb-5">
                            <a href="{{ path('admin_dashboard') }}" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left me-2"></i> Retour au dashboard
                            </a>
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-save me-2"></i> Enregistrer
                            </button>
                        </div>
                    </div>

                    <aside class="col-xl-4">
                        <div class="card mb-4">
                            <div class="card-header">
                                <h5 class="mb-0"><i class="fab fa-google me-2"></i> Apercu Google</h5>
                            </div>
                            <div class="card-body">
                                <p class="small text-success mb-1">{{ app.request.schemeAndHttpHost }}</p>
                                <h6 class="text-primary mb-2" id="seoPreviewTitle">{{ form.vars.value.seoTitle|default('Bella Couture - Mode feminine elegante') }}</h6>
                                <p class="small text-muted mb-0" id="seoPreviewDescription">{{ form.vars.value.seoDescription|default('Boutique de mode feminine a Sousse.') }}</p>
                            </div>
                        </div>

                        <div class="alert alert-info">
                            <h6 class="alert-heading">Bonnes pratiques</h6>
                            <p class="mb-2">Gardez le titre clair, la description attractive, et utilisez une image de partage nette.</p>
                            <p class="mb-0">Les pages panier, commande et recherche sont protegees automatiquement avec <code>noindex</code>.</p>
                        </div>
                    </aside>
                </div>
            {{ form_end(form) }}
        </main>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const shippingFeeInput = document.getElementById('{{ form.shippingFee.vars.id }}');
            document.querySelectorAll('[data-shipping-fee]').forEach(function (button) {
                button.addEventListener('click', function () {
                    shippingFeeInput.value = button.dataset.shippingFee;
                    shippingFeeInput.focus();
                });
            });

            const titleInput = document.getElementById('{{ form.seoTitle.vars.id }}');
            const descriptionInput = document.getElementById('{{ form.seoDescription.vars.id }}');
            const titlePreview = document.getElementById('seoPreviewTitle');
            const descriptionPreview = document.getElementById('seoPreviewDescription');

            function refreshPreview() {
                titlePreview.textContent = titleInput.value || 'Bella Couture - Mode feminine elegante';
                descriptionPreview.textContent = descriptionInput.value || 'Boutique de mode feminine a Sousse.';
            }

            titleInput.addEventListener('input', refreshPreview);
            descriptionInput.addEventListener('input', refreshPreview);
        });
    </script>
{% endblock %}
