        <script>
            (function () {
                try {
                    var loader = document.getElementById('bellaPageLoader');
                    if (!loader) return;

                    var hidden = false;
                    function hideFallback(delay) {
                        if (hidden) return;
                        hidden = true;
                        window.setTimeout(function () {
                            loader.classList.add('is-hidden');
                            loader.classList.remove('is-active');
                            document.body.classList.remove('bella-loader-lock');
                            if (window.console && console.info) console.info('bellaPageLoader: fallback hidden');
                        }, delay || 0);
                    }

                    // If page becomes interactive/complete, hide shortly after
                    if (document.readyState === 'interactive' || document.readyState === 'complete') {
                        hideFallback(120);
                    } else {
                        window.addEventListener('load', function () { hideFallback(120); }, {once: true});
                        document.addEventListener && document.addEventListener('turbo:load', function () { hideFallback(120); }, {once: true});
                    }

                    // Final safety: always hide after 10s to avoid permanent blocking
                    window.setTimeout(function () { hideFallback(0); }, 10000);
                } catch (e) {
                    try { console.error('bellaPageLoader fallback error', e); } catch (__){}
                }
            })();
        </script>
