<!DOCTYPE html>
<html lang="{{ app.request.locale }}" dir="{{ app.request.locale == 'ar' ? 'rtl' : 'ltr' }}">
    {% set current_route = app.request.attributes.get('_route')|default('') %}
    {% set is_admin_area = current_route starts with 'admin_' %}
    {% set settings = site_settings() %}
    {% set default_seo_title = settings and settings|localized('seoTitle') ? settings|localized('seoTitle') : 'Bella Couture - Mode feminine elegante' %}
    {% set default_seo_description = settings and settings|localized('seoDescription') ? settings|localized('seoDescription') : 'Boutique de mode feminine a Sousse: vetements elegants, collections tendance, tailles et couleurs au choix avec livraison en Tunisie.' %}
    {% set default_seo_keywords = settings and settings|localized('seoKeywords') ? settings|localized('seoKeywords') : 'mode feminine, boutique femme, vetements femme, Bella Couture, Sousse, Tunisie' %}
    {% set default_seo_author = settings and settings.seoAuthor ? settings.seoAuthor : 'Bella Couture' %}
    {% set default_seo_image = settings and settings.seoImage ? settings.seoImage : 'logo/logo.webp' %}
    {% set default_robots = is_admin_area or (settings and not settings.seoIndexingEnabled) ? 'noindex, nofollow' : 'index, follow' %}
    {% set default_canonical = app.request.schemeAndHttpHost ~ app.request.pathInfo %}
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        {% set seo_description %}{% block meta_description %}{{ default_seo_description }}{% endblock %}{% endset %}
        {% set seo_keywords %}{% block meta_keywords %}{{ default_seo_keywords }}{% endblock %}{% endset %}
        {% set seo_robots %}{% block robots %}{{ default_robots }}{% endblock %}{% endset %}
        {% set seo_type %}{% block og_type %}website{% endblock %}{% endset %}
        {% set seo_canonical %}{% block canonical_url %}{{ default_canonical }}{% endblock %}{% endset %}
        {% set seo_image %}{% block meta_image %}{{ default_seo_image }}{% endblock %}{% endset %}
        {% set seo_title = block('title')|striptags|trim %}
        {% set seo_image_value = seo_image|striptags|trim %}
        {% set seo_image_url = seo_image_value starts with 'http' ? seo_image_value : absolute_url(asset(seo_image_value starts with '/' ? seo_image_value|slice(1) : seo_image_value)) %}
        <meta name="description" content="{{ seo_description|striptags|trim }}">
        <meta name="keywords" content="{{ seo_keywords|striptags|trim }}">
        <meta name="author" content="{{ default_seo_author }}">
        <meta name="robots" content="{{ seo_robots|striptags|trim }}">
        <link rel="canonical" href="{{ seo_canonical|striptags|trim }}">
        <meta property="og:locale" content="{{ app.request.locale == 'ar' ? 'ar_TN' : 'fr_TN' }}">
        <meta property="og:type" content="{{ seo_type|striptags|trim }}">
        <meta property="og:site_name" content="Bella Couture">
        <meta property="og:title" content="{{ seo_title }}">
        <meta property="og:description" content="{{ seo_description|striptags|trim }}">
        <meta property="og:url" content="{{ seo_canonical|striptags|trim }}">
        <meta property="og:image" content="{{ seo_image_url }}">
        <meta name="twitter:card" content="summary_large_image">
        <meta name="twitter:title" content="{{ seo_title }}">
        <meta name="twitter:description" content="{{ seo_description|striptags|trim }}">
        <meta name="twitter:image" content="{{ seo_image_url }}">
        <link rel="icon" href="{{ asset('logo/logo.png') }}" />
        {% block structured_data %}
            {% if not is_admin_area %}
                <script type="application/ld+json">
                    {{ {
                        '@context': 'https://schema.org',
                        '@type': 'ClothingStore',
                        name: 'Bella Couture',
                        url: app.request.schemeAndHttpHost ~ path('home'),
                        image: absolute_url(asset('logo/logo.webp')),
                        address: {
                            '@type': 'PostalAddress',
                            addressLocality: 'Sousse',
                            addressCountry: 'TN'
                        },
                        telephone: '+21621201092',
                        sameAs: [
                            'https://www.facebook.com/profile.php?id=100031130891935',
                            'https://www.instagram.com/Fashion_time_sousse/'
                        ]
                    }|json_encode(constant('JSON_UNESCAPED_SLASHES'))|raw }}
                </script>
                <script type="application/ld+json">
                    {{ {
                        '@context': 'https://schema.org',
                        '@type': 'WebSite',
                        name: 'Bella Couture',
                        url: app.request.schemeAndHttpHost ~ path('home'),
                        potentialAction: {
                            '@type': 'SearchAction',
                            target: app.request.schemeAndHttpHost ~ path('search') ~ '?q={search_term_string}',
                            'query-input': 'required name=search_term_string'
                        }
                    }|json_encode(constant('JSON_UNESCAPED_SLASHES'))|raw }}
                </script>
            {% endif %}
        {% endblock %}
        <title>{% block title %}{{ default_seo_title }}{% endblock %}</title>
        <link href="{{ asset('css/bootstrap.min.css') }}" rel="stylesheet">
        <link href="{{ asset('css/all.min.css') }}" rel="stylesheet">
        <style>
            .bella-page-loader {
                position: fixed;
                inset: 0;
                z-index: 3000;
                display: grid;
                place-items: center;
                padding: 1.5rem;
                background:
                    linear-gradient(135deg, rgba(255, 247, 249, 0.98) 0%, rgba(255, 255, 255, 0.97) 48%, rgba(247, 238, 242, 0.98) 100%);
                color: #2f2430;
                opacity: 0;
                visibility: hidden;
                pointer-events: none;
                transition: opacity 0.35s ease, visibility 0.35s ease;
            }

            .admin-shell .bella-page-loader {
                background:
                    linear-gradient(135deg, rgba(255, 248, 251, 0.98) 0%, rgba(255, 255, 255, 0.97) 50%, rgba(247, 250, 249, 0.98) 100%);
            }

            .bella-page-loader.is-hidden {
                opacity: 0;
                visibility: hidden;
                pointer-events: none;
            }

            .bella-page-loader.is-active {
                opacity: 1;
                visibility: visible;
                pointer-events: auto;
            }

            .bella-loader-content {
                width: min(100%, 430px);
                text-align: center;
            }

            .bella-loader-mark {
                position: relative;
                width: 96px;
                height: 96px;
                display: grid;
                place-items: center;
                margin: 0 auto 1.25rem;
            }

            .bella-loader-mark::before,
            .bella-loader-mark::after {
                content: "";
                position: absolute;
                inset: 0;
                border: 1px solid rgba(178, 58, 99, 0.22);
                border-radius: 50%;
                animation: bellaLoaderRing 1.8s ease-in-out infinite;
            }

            .bella-loader-mark::after {
                inset: 10px;
                border-color: rgba(195, 154, 75, 0.34);
                animation-delay: -0.55s;
            }

            .bella-loader-mark img {
                position: relative;
                z-index: 1;
                width: 64px;
                max-height: 64px;
                object-fit: contain;
                filter: drop-shadow(0 10px 18px rgba(87, 49, 65, 0.16));
                animation: bellaLoaderLogo 1.8s ease-in-out infinite;
            }

            .bella-loader-title {
                margin: 0;
                background: linear-gradient(90deg, #8f2f52, #b23a63, #c39a4b, #8f2f52);
                background-size: 260% 100%;
                -webkit-background-clip: text;
                background-clip: text;
                color: transparent;
                font-family: Georgia, "Times New Roman", serif;
                font-size: 3.35rem;
                font-weight: 700;
                line-height: 1;
                letter-spacing: 0;
                animation: bellaLoaderText 2.4s ease-in-out infinite;
            }

            .bella-loader-subtitle {
                margin: 0.85rem auto 1.35rem;
                max-width: 330px;
                color: #5d4754;
                font-size: 0.98rem;
                line-height: 1.55;
                font-weight: 650;
            }

            .bella-loader-track {
                position: relative;
                width: min(100%, 260px);
                height: 4px;
                margin: 0 auto;
                overflow: hidden;
                border-radius: 999px;
                background: rgba(234, 221, 227, 0.92);
            }

            .bella-loader-track::before {
                content: "";
                position: absolute;
                inset: 0 auto 0 0;
                width: 42%;
                border-radius: inherit;
                background: linear-gradient(90deg, #b23a63, #c39a4b);
                animation: bellaLoaderTrack 1.25s ease-in-out infinite;
            }

            .bella-loader-note {
                display: block;
                margin-top: 1rem;
                color: #7b717a;
                font-size: 0.78rem;
                font-weight: 800;
                text-transform: uppercase;
            }

            body.bella-loader-lock {
                overflow: hidden;
            }

            @keyframes bellaLoaderRing {
                0% {
                    transform: scale(0.86);
                    opacity: 0.28;
                }

                50% {
                    transform: scale(1);
                    opacity: 1;
                }

                100% {
                    transform: scale(0.86);
                    opacity: 0.28;
                }
            }

            @keyframes bellaLoaderLogo {
                0%,
                100% {
                    transform: translateY(0);
                }

                50% {
                    transform: translateY(-4px);
                }
            }

            @keyframes bellaLoaderText {
                0%,
                100% {
                    background-position: 0% 50%;
                }

                50% {
                    background-position: 100% 50%;
                }
            }

            @keyframes bellaLoaderTrack {
                0% {
                    transform: translateX(-110%);
                }

                100% {
                    transform: translateX(260%);
                }
            }

            @media (prefers-reduced-motion: reduce) {
                .bella-loader-mark::before,
                .bella-loader-mark::after,
                .bella-loader-mark img,
                .bella-loader-title,
                .bella-loader-track::before {
                    animation: none;
                }
            }

            @media (max-width: 575.98px) {
                .bella-loader-title {
                    font-size: 2.45rem;
                }

                .bella-loader-subtitle {
                    font-size: 0.94rem;
                }
            }

            .swal2-popup.bella-alert {
                border: 1px solid #eadde3;
                border-radius: 18px;
                color: #2f2430;
                box-shadow: 0 18px 55px rgba(87, 49, 65, 0.14);
                font-family: Inter, "Segoe UI", system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
            }

            .swal2-popup.bella-alert .swal2-title {
                color: #2f2430;
                font-weight: 850;
                letter-spacing: 0;
            }

            .swal2-popup.bella-alert .swal2-html-container {
                color: #7b717a;
                line-height: 1.6;
            }

            .swal2-popup.bella-alert .swal2-confirm {
                border-radius: 999px !important;
                background: linear-gradient(135deg, #b23a63, #8f2f52) !important;
                box-shadow: 0 10px 24px rgba(178, 58, 99, 0.24) !important;
                font-weight: 800;
                padding: 0.72rem 1.35rem;
            }

            .swal2-popup.bella-alert .swal2-icon.swal2-success,
            .swal2-popup.bella-alert .swal2-icon.swal2-info,
            .swal2-popup.bella-alert .swal2-icon.swal2-warning,
            .swal2-popup.bella-alert .swal2-icon.swal2-error {
                margin-top: 1.6rem;
            }

            .swal2-popup.bella-alert .swal2-icon.swal2-success {
                border-color: #2f8f72;
                color: #2f8f72;
            }

            .swal2-popup.bella-alert .swal2-icon.swal2-info {
                border-color: #b23a63;
                color: #b23a63;
            }

            @media (max-width: 575.98px) {
                .swal2-popup.bella-alert {
                    width: calc(100% - 2rem) !important;
                    border-radius: 16px;
                }
            }

            .language-switcher {
                display: inline-flex;
                align-items: center;
                gap: 0.25rem;
                padding: 0.2rem;
                border: 1px solid rgba(178, 58, 99, 0.18);
                border-radius: 999px;
                background: rgba(255, 255, 255, 0.76);
            }

            .language-switcher a {
                min-width: 2.25rem;
                padding: 0.28rem 0.58rem;
                border-radius: 999px;
                color: #5d4754;
                font-size: 0.78rem;
                font-weight: 850;
                line-height: 1;
                text-align: center;
                text-decoration: none;
            }

            .language-switcher a.active {
                background: #b23a63;
                color: #fff;
            }

            html[dir="rtl"] body {
                text-align: right;
            }

            html[dir="rtl"] .navbar-nav,
            html[dir="rtl"] .admin-topbar-actions,
            html[dir="rtl"] .d-flex {
                direction: rtl;
            }

            html[dir="rtl"] .dropdown-menu {
                text-align: right;
            }

            html[dir="rtl"] .me-1,
            html[dir="rtl"] .me-2,
            html[dir="rtl"] .me-3 {
                margin-right: 0 !important;
            }

            html[dir="rtl"] .me-1 {
                margin-left: 0.25rem !important;
            }

            html[dir="rtl"] .me-2 {
                margin-left: 0.5rem !important;
            }

            html[dir="rtl"] .me-3 {
                margin-left: 1rem !important;
            }

            html[dir="rtl"] .ms-auto {
                margin-left: 0 !important;
                margin-right: auto !important;
            }
        </style>
        {% if is_admin_area %}
            <link href="{{ asset('css/select2.min.css') }}?v=select2-admin-1" rel="stylesheet">
            <link href="{{ asset('css/admin-ux.css') }}?v=admin-fem-7" rel="stylesheet">
        {% else %}
            <link href="{{ asset('css/front-ux.css') }}?v=front-mobile-5" rel="stylesheet">
        {% endif %}
        {% if app.request.locale == 'ar' %}
            <link href="{{ asset('css/rtl.css') }}?v=rtl-1" rel="stylesheet">
        {% endif %}
        {% block stylesheets %}{% endblock %}
    </head>
    <body class="{{ is_admin_area ? 'admin-shell' : 'front-shell' }} {{ app.request.locale == 'ar' ? 'rtl-locale' : 'ltr-locale' }}">
        {% set locale_query_ar = app.request.query.all|merge({'locale': 'ar'}) %}
        {% set locale_query_fr = app.request.query.all|merge({'locale': 'fr'}) %}
        <div id="bellaPageLoader" class="bella-page-loader is-hidden" role="status" aria-live="polite" aria-label="Chargement">
            <div class="bella-loader-content">
                <div class="bella-loader-mark">
                    <img src="{{ asset('logo/logo.webp') }}" alt="Bella Couture">
                </div>
                <p class="bella-loader-title">Bella Couture</p>
                <p class="bella-loader-subtitle">La boutique se prepare avec elegance.</p>
                <div class="bella-loader-track" aria-hidden="true"></div>
                <span class="bella-loader-note">Nouvelle allure en cours</span>
            </div>
        </div>
        <script>
            (function () {
                var loader = document.getElementById('bellaPageLoader');
                if (!loader) return;

                function hideLoader(delay) {
                    window.setTimeout(function () {
                        loader.classList.add('is-hidden');
                        loader.classList.remove('is-active');
                        document.body.classList.remove('bella-loader-lock');
                    }, delay || 0);
                }

                if (document.readyState === 'interactive' || document.readyState === 'complete') {
                    hideLoader(120);
                } else {
                    document.addEventListener('DOMContentLoaded', function () { hideLoader(120); }, { once: true });
                    window.addEventListener('load', function () { hideLoader(120); }, { once: true });
                    window.addEventListener('pageshow', function () { hideLoader(120); });
                }

                window.setTimeout(function () { hideLoader(0); }, 3000);
            })();
        </script>

        {% if is_admin_area %}
        <nav class="admin-topbar">
            <div class="container-fluid">
                <a class="admin-brand" href="{{ path('admin_dashboard') }}" aria-label="Administration Bella Couture">
                    <img src="{{ asset('/logo/logo.webp') }}" alt="Bella Couture">
                    <span>Administration</span>
                </a>

                <div class="admin-topbar-actions">
                    <div class="language-switcher" aria-label="Langue">
                        <a href="{{ path(current_route, app.request.attributes.get('_route_params')|default({})|merge(locale_query_ar)) }}" class="{{ app.request.locale == 'ar' ? 'active' : '' }}" lang="ar" hreflang="ar" data-turbo="false">{{ app.request.locale == 'ar' ? 'العربية' : 'AR' }}</a>
                        <a href="{{ path(current_route, app.request.attributes.get('_route_params')|default({})|merge(locale_query_fr)) }}" class="{{ app.request.locale == 'fr' ? 'active' : '' }}" lang="fr" hreflang="fr" data-turbo="false">{{ app.request.locale == 'ar' ? 'الفرنسية' : 'FR' }}</a>
                    </div>
                    <a class="btn btn-outline-secondary btn-sm" href="{{ path('home') }}" target="_blank">
                        <i class="fas fa-store me-1"></i> Voir la boutique
                    </a>
                    {% if app.user %}
                        <span class="admin-user">{{ app.user.firstName|default('Admin') }}</span>
                    {% endif %}
                    <a class="btn btn-outline-secondary btn-sm" href="{{ path('admin_change_password') }}">
                        <i class="fas fa-key me-1"></i> {{ app.request.locale == 'ar' ? 'كلمة المرور' : 'Mot de passe' }}
                    </a>
                    <a class="btn btn-primary btn-sm" href="{{ path('app_logout') }}">
                        <i class="fas fa-sign-out-alt me-1"></i> {{ app.request.locale == 'ar' ? 'تسجيل الخروج' : 'Deconnexion' }}
                    </a>
                </div>
            </div>
        </nav>
        {% else %}
        <nav class="navbar navbar-expand-lg navbar-light sticky-top">
            <div class="container">
                <a class="navbar-brand" href="{{ path('home') }}" aria-label="Bella Couture">
                    <img src="{{ asset('/logo/logo.webp') }}" alt="Bella Couture">
                </a>

                <form class="search-form d-none d-lg-flex me-lg-3" method="GET" action="{{ path('search') }}">
                    <div class="input-group">
                        <input type="text" class="form-control" name="q" placeholder="Rechercher un produit..." value="{{ app.request.query.get('q') }}" id="searchInputDesktop">
                        <button class="btn btn-primary" type="submit" aria-label="Rechercher">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                </form>

                <div class="cart-container order-lg-3">
                    <a class="nav-link cart-icon" href="{{ path('cart') }}" aria-label="Panier">
                        <i class="fas fa-shopping-bag fa-lg"></i>
                        {% set cart_count = app.session.get('cart', [])|length %}
                        {% if cart_count > 0 %}
                            <span class="badge">{{ cart_count }}</span>
                        {% endif %}
                    </a>
                </div>

                <div class="language-switcher order-lg-3 ms-2" aria-label="Langue">
                    <a href="{{ path(current_route, app.request.attributes.get('_route_params')|default({})|merge(locale_query_ar)) }}" class="{{ app.request.locale == 'ar' ? 'active' : '' }}" lang="ar" hreflang="ar" data-turbo="false">{{ app.request.locale == 'ar' ? 'العربية' : 'AR' }}</a>
                    <a href="{{ path(current_route, app.request.attributes.get('_route_params')|default({})|merge(locale_query_fr)) }}" class="{{ app.request.locale == 'fr' ? 'active' : '' }}" lang="fr" hreflang="fr" data-turbo="false">{{ app.request.locale == 'ar' ? 'الفرنسية' : 'FR' }}</a>
                </div>

                <button class="navbar-toggler order-lg-4" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain" aria-controls="navbarMain" aria-expanded="false" aria-label="Menu">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse order-lg-2" id="navbarMain">
                    <form class="search-form d-lg-none mb-3" method="GET" action="{{ path('search') }}">
                        <div class="input-group">
                            <input type="text" class="form-control" name="q" placeholder="Rechercher un produit..." value="{{ app.request.query.get('q') }}" id="searchInputMobile">
                            <button class="btn btn-primary" type="submit" aria-label="Rechercher">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>
                    </form>

                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link {{ app.request.get('_route') == 'home' ? 'active' : '' }}" href="{{ path('home') }}">
                                <i class="fas fa-home me-1"></i> Accueil
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link {{ app.request.get('_route') == 'products' ? 'active' : '' }}" href="{{ path('products') }}">
                                <i class="fas fa-tshirt me-1"></i> Boutique
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link {{ app.request.get('_route') == 'contact' ? 'active' : '' }}" href="{{ path('contact') }}">
                                <i class="fas fa-envelope me-1"></i> Contact
                            </a>
                        </li>
                    </ul>

                    <ul class="navbar-nav align-items-lg-center">
                        {% if is_granted('ROLE_ADMIN') %}
                            {% set pending_orders = count_pending_orders() %}
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle position-relative" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <span class="user-avatar me-2"><i class="fas fa-cog"></i></span>
                                    Admin
                                    {% if pending_orders > 0 %}
                                        <span class="badge admin-badge">{{ pending_orders }}</span>
                                    {% endif %}
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><h6 class="dropdown-header">Administration</h6></li>
                                    <li><a class="dropdown-item" href="{{ path('admin_dashboard') }}"><i class="fas fa-tachometer-alt me-2"></i> Tableau de bord</a></li>
                                    <li><a class="dropdown-item" href="{{ path('admin_products') }}"><i class="fas fa-tshirt me-2"></i> Produits</a></li>
                                    <li><a class="dropdown-item" href="{{ path('admin_orders') }}"><i class="fas fa-shopping-cart me-2"></i> Commandes</a></li>
                                    <li><a class="dropdown-item" href="{{ path('admin_slider') }}"><i class="fas fa-images me-2"></i> Diaporama</a></li>
                                    <li><a class="dropdown-item" href="{{ path('admin_categories') }}"><i class="fas fa-tags me-2"></i> Catégories</a></li>
                                    <li><a class="dropdown-item" href="{{ path('admin_sizes') }}"><i class="fas fa-ruler me-2"></i> Tailles</a></li>
                                    <li><a class="dropdown-item" href="{{ path('admin_settings') }}"><i class="fas fa-cog me-2"></i> Parametres & SEO</a></li>
                                    <li><a class="dropdown-item" href="{{ path('admin_promotion_index') }}"><i class="fas fa-gift me-2"></i> Promotions</a></li>
                                    <li><a class="dropdown-item" href="{{ path('admin_change_password') }}"><i class="fas fa-key me-2"></i> {{ app.request.locale == 'ar' ? 'تغيير كلمة المرور' : 'Changer le mot de passe' }}</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" href="{{ path('app_logout') }}"><i class="fas fa-sign-out-alt me-2"></i> {{ app.request.locale == 'ar' ? 'تسجيل الخروج' : 'Deconnexion' }}</a></li>
                                </ul>
                            </li>
                        {% elseif app.user %}
                            <li class="nav-item dropdown user-menu">
                                <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <span class="user-avatar me-2">
                                        {{ app.user.firstName|first|upper }}{{ app.user.lastName|first|upper }}
                                    </span>
                                    {{ app.request.locale == 'ar' ? 'حسابي' : 'Mon compte' }}
                                </a>
