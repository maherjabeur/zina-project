                    'Supprimer ce message ?': 'هل تريد حذف هذه الرسالة؟',
                    'Êtes-vous sûr de vouloir supprimer cette commande ?': 'هل أنت متأكد من حذف هذا الطلب؟',
                    'Êtes-vous sûr de vouloir supprimer ce produit ?': 'هل أنت متأكد من حذف هذا المنتج؟',
                    'Êtes-vous sûr de vouloir supprimer cette image ?': 'هل أنت متأكد من حذف هذه الصورة؟',
                    'Êtes-vous sûr de vouloir supprimer cette image du diaporama ?': 'هل أنت متأكد من حذف هذه الصورة من العرض؟',
                    'Êtes-vous sûr de vouloir supprimer cette catégorie ?': 'هل أنت متأكد من حذف هذا القسم؟',
                    'Êtes-vous sûr de vouloir supprimer cette taille ?': 'هل أنت متأكد من حذف هذا المقاس؟',
                    'Êtes-vous sûr de vouloir supprimer cette promotion ?': 'هل أنت متأكد من حذف هذا العرض؟'
                };

                function translateFlashMessage(message) {
                    if (!isArabic) {
                        return message;
                    }

                    const text = String(message || '');
                    if (arabicFlashMessages[text]) {
                        return arabicFlashMessages[text];
                    }

                    const prefixMap = [
                        ['Erreur lors de la suppression de la commande:', 'حدث خطأ أثناء حذف الطلب:'],
                        ['Erreur lors de la suppression du produit:', 'حدث خطأ أثناء حذف المنتج:'],
                        ['Erreur lors de la suppression de la promotion:', 'حدث خطأ أثناء حذف العرض:'],
                        ["Commande mise à jour mais erreur lors de l'envoi de l'email:", 'تم تحديث الطلب لكن حدث خطأ أثناء إرسال البريد:'],
                        ["Commande mise a jour mais erreur lors de l'envoi de l'email:", 'تم تحديث الطلب لكن حدث خطأ أثناء إرسال البريد:']
                    ];

                    for (const pair of prefixMap) {
                        if (text.startsWith(pair[0])) {
                            return pair[1] + text.slice(pair[0].length);
                        }
                    }

                    return text;
                }

                if (isArabic && typeof window.confirm === 'function') {
                    const nativeConfirm = window.confirm.bind(window);
                    window.confirm = function (message) {
                        return nativeConfirm(translateFlashMessage(message));
                    };
                }

                const flashes = [
                    {% for label, messages in app.flashes %}
                        {% set normalized_label = label == 'danger' ? 'error' : (label == 'notice' ? 'info' : label) %}
                        {% set alert_icon = normalized_label in ['success', 'error', 'warning', 'info', 'question'] ? normalized_label : 'info' %}
                        {% set alert_title = app.request.locale == 'ar' ? 'معلومة' : 'Information' %}
                        {% if alert_icon == 'success' %}
                            {% set alert_title = app.request.locale == 'ar' ? 'نجاح' : 'Succes' %}
                        {% elseif alert_icon == 'error' %}
                            {% set alert_title = app.request.locale == 'ar' ? 'خطأ' : 'Erreur' %}
                        {% elseif alert_icon == 'warning' %}
                            {% set alert_title = app.request.locale == 'ar' ? 'تنبيه' : 'Attention' %}
                        {% elseif alert_icon == 'question' %}
                            {% set alert_title = app.request.locale == 'ar' ? 'تأكيد' : 'Confirmation' %}
                        {% endif %}
                        {% for message in messages %}
                            {
                                icon: {{ alert_icon|json_encode(constant('JSON_HEX_TAG') b-or constant('JSON_HEX_APOS') b-or constant('JSON_HEX_AMP') b-or constant('JSON_HEX_QUOT'))|raw }},
                                title: {{ alert_title|json_encode(constant('JSON_HEX_TAG') b-or constant('JSON_HEX_APOS') b-or constant('JSON_HEX_AMP') b-or constant('JSON_HEX_QUOT'))|raw }},
                                message: {{ message|json_encode(constant('JSON_HEX_TAG') b-or constant('JSON_HEX_APOS') b-or constant('JSON_HEX_AMP') b-or constant('JSON_HEX_QUOT'))|raw }}
                            },
                        {% endfor %}
                    {% endfor %}
                ];

                if (!flashes.length) {
                    return;
                }

                function showFallback(message) {
                    window.alert(message);
                }

                function showNext(index) {
                    if (index >= flashes.length) {
                        return;
                    }

                    const flash = flashes[index];
                    const text = translateFlashMessage(flash.message || '');

                    if (!window.Swal) {
                        showFallback(text);
                        showNext(index + 1);
                        return;
                    }

                    Swal.fire({
                        title: flash.title || alertCopy.info,
                        text: text,
                        icon: flash.icon || 'info',
                        confirmButtonText: alertCopy.ok,
                        customClass: {
                            popup: 'bella-alert'
                        },
                        buttonsStyling: true
                    }).then(function () {
                        showNext(index + 1);
                    });
                }

                showNext(0);
            });
        </script>
