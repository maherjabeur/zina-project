        <script src="{{ asset('js/jquery-3.7.1.min.js') }}"></script>
        <script src="{{ asset('js/bootstrap.bundle.min.js') }}"></script>
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                const flashes = [
                    {% for label, messages in app.flashes %}
                        {% set normalized_label = label == 'danger' ? 'error' : (label == 'notice' ? 'info' : label) %}
                        {% set alert_icon = normalized_label in ['success', 'error', 'warning', 'info', 'question'] ? normalized_label : 'info' %}
                        {% set alert_title = 'Information' %}
                        {% if alert_icon == 'success' %}
                            {% set alert_title = 'Succes' %}
                        {% elseif alert_icon == 'error' %}
                            {% set alert_title = 'Erreur' %}
                        {% elseif alert_icon == 'warning' %}
                            {% set alert_title = 'Attention' %}
                        {% elseif alert_icon == 'question' %}
                            {% set alert_title = 'Confirmation' %}
                        {% endif %}
                        {% for message in messages %}
                            {
                                icon: {{ alert_icon|json_encode(constant('JSON_HEX_TAG') b-or constant('JSON_HEX_APOS') b-or constant('JSON_HEX_AMP') b-or constant('JSON_HEX_QUOT'))|raw }},
                                title: {{ alert_title|json_encode(constant('JSON_HEX_TAG') b-or constant('JSON_HEX_APOS') b-or constant('JSON_HEX_AMP') b-or constant('JSON_HEX_QUOT'))|raw }},
                                message: {{ message|json_encode(constant('JSON_HEX_TAG') b-or constant('JSON_HEX_APOS') b-or constant('JSON_HEX_AMP') b-or constant('JSON_HEX_QUOT'))|raw }}
                            },
                        {% endfor %}
                    {% endfor %}
                ];

                if (!flashes.length) {
                    return;
                }

                function showFallback(message) {
                    window.alert(message);
                }

                function showNext(index) {
                    if (index >= flashes.length) {
                        return;
                    }

                    const flash = flashes[index];
                    const text = String(flash.message || '');

                    if (!window.Swal) {
                        showFallback(text);
                        showNext(index + 1);
                        return;
                    }

                    Swal.fire({
                        title: flash.title || 'Information',
                        text: text,
                        icon: flash.icon || 'info',
                        confirmButtonText: 'OK',
                        customClass: {
                            popup: 'bella-alert'
                        },
                        buttonsStyling: true
                    }).then(function () {
                        showNext(index + 1);
                    });
                }

                showNext(0);
            });
        </script>
        {% if not is_admin_area %}
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                const heroCarousel = document.querySelector('#heroCarousel');
                if (heroCarousel) {
                    new bootstrap.Carousel(heroCarousel, {
                        interval: 5000,
                        wrap: true
                    });
                }

                document.querySelectorAll('.search-form').forEach(function (form) {
                    form.addEventListener('submit', function (event) {
                        const input = form.querySelector('input[name="q"]');
                        const searchTerm = input ? input.value.trim() : '';
                        if (!searchTerm) {
                            event.preventDefault();
                        }
                    });
                });

                const searchInputs = document.querySelectorAll('#searchInputDesktop, #searchInputMobile');
                let searchTimeout;

                function hideSuggestions() {
                    document.querySelectorAll('.search-suggestions').forEach(function (node) {
                        node.remove();
                    });
                }

                function showSuggestions(input, suggestions) {
                    hideSuggestions();
                    if (!suggestions.length) {
                        return;
                    }

                    const suggestionsDiv = document.createElement('div');
                    suggestionsDiv.className = 'search-suggestions';

                    suggestions.forEach(function (suggestion) {
                        const item = document.createElement('button');
                        item.type = 'button';
                        item.className = 'suggestion-item';
                        item.innerHTML = '<i class="fas fa-search me-2 text-muted"></i>';
                        item.appendChild(document.createTextNode(suggestion));
                        item.addEventListener('click', function () {
                            input.value = suggestion;
                            window.location.href = '{{ path('search') }}?q=' + encodeURIComponent(suggestion);
                        });
                        suggestionsDiv.appendChild(item);
                    });

                    input.closest('.input-group').appendChild(suggestionsDiv);
                }

                searchInputs.forEach(function (input) {
                    input.addEventListener('input', function () {
                        clearTimeout(searchTimeout);
                        const query = input.value.trim();
                        if (query.length < 2) {
                            hideSuggestions();
                            return;
                        }

                        searchTimeout = setTimeout(function () {
                            fetch('{{ path('search_suggestions') }}?q=' + encodeURIComponent(query))
                                .then(function (response) { return response.json(); })
                                .then(function (suggestions) { showSuggestions(input, suggestions); })
                                .catch(hideSuggestions);
                        }, 350);
                    });

                    input.addEventListener('blur', function () {
                        setTimeout(hideSuggestions, 180);
                    });
                });
            });
        </script>
        {% endif %}
        {% block javascripts %}{% endblock %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
    </body>
</html>
