<!DOCTYPE html>
<html lang="fr">
    {% set current_route = app.request.attributes.get('_route')|default('') %}
    {% set is_admin_area = current_route starts with 'admin_' %}
    {% set settings = site_settings() %}
    {% set default_seo_title = settings and settings.seoTitle ? settings.seoTitle : 'Bella Couture - Mode feminine elegante' %}
    {% set default_seo_description = settings and settings.seoDescription ? settings.seoDescription : 'Boutique de mode feminine a Sousse: vetements elegants, collections tendance, tailles et couleurs au choix avec livraison en Tunisie.' %}
    {% set default_seo_keywords = settings and settings.seoKeywords ? settings.seoKeywords : 'mode feminine, boutique femme, vetements femme, Bella Couture, Sousse, Tunisie' %}
    {% set default_seo_author = settings and settings.seoAuthor ? settings.seoAuthor : 'Bella Couture' %}
    {% set default_seo_image = settings and settings.seoImage ? settings.seoImage : 'logo/logo.webp' %}
    {% set default_robots = is_admin_area or (settings and not settings.seoIndexingEnabled) ? 'noindex, nofollow' : 'index, follow' %}
    {% set default_canonical = app.request.schemeAndHttpHost ~ app.request.pathInfo %}
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        {% set seo_description %}{% block meta_description %}{{ default_seo_description }}{% endblock %}{% endset %}
        {% set seo_keywords %}{% block meta_keywords %}{{ default_seo_keywords }}{% endblock %}{% endset %}
        {% set seo_robots %}{% block robots %}{{ default_robots }}{% endblock %}{% endset %}
        {% set seo_type %}{% block og_type %}website{% endblock %}{% endset %}
        {% set seo_canonical %}{% block canonical_url %}{{ default_canonical }}{% endblock %}{% endset %}
        {% set seo_image %}{% block meta_image %}{{ default_seo_image }}{% endblock %}{% endset %}
        {% set seo_title = block('title')|striptags|trim %}
        {% set seo_image_value = seo_image|striptags|trim %}
        {% set seo_image_url = seo_image_value starts with 'http' ? seo_image_value : absolute_url(asset(seo_image_value starts with '/' ? seo_image_value|slice(1) : seo_image_value)) %}
        <meta name="description" content="{{ seo_description|striptags|trim }}">
        <meta name="keywords" content="{{ seo_keywords|striptags|trim }}">
        <meta name="author" content="{{ default_seo_author }}">
        <meta name="robots" content="{{ seo_robots|striptags|trim }}">
        <link rel="canonical" href="{{ seo_canonical|striptags|trim }}">
        <meta property="og:locale" content="fr_TN">
        <meta property="og:type" content="{{ seo_type|striptags|trim }}">
        <meta property="og:site_name" content="Bella Couture">
        <meta property="og:title" content="{{ seo_title }}">
        <meta property="og:description" content="{{ seo_description|striptags|trim }}">
        <meta property="og:url" content="{{ seo_canonical|striptags|trim }}">
        <meta property="og:image" content="{{ seo_image_url }}">
        <meta name="twitter:card" content="summary_large_image">
        <meta name="twitter:title" content="{{ seo_title }}">
        <meta name="twitter:description" content="{{ seo_description|striptags|trim }}">
        <meta name="twitter:image" content="{{ seo_image_url }}">
        {% block structured_data %}
            {% if not is_admin_area %}
                <script type="application/ld+json">
                    {{ {
                        '@context': 'https://schema.org',
                        '@type': 'ClothingStore',
                        name: 'Bella Couture',
                        url: app.request.schemeAndHttpHost ~ path('home'),
                        image: absolute_url(asset('logo/logo.webp')),
                        address: {
                            '@type': 'PostalAddress',
                            addressLocality: 'Sousse',
                            addressCountry: 'TN'
                        },
                        telephone: '+21621201092',
                        sameAs: [
                            'https://www.facebook.com/profile.php?id=100031130891935',
                            'https://www.instagram.com/Fashion_time_sousse/'
                        ]
                    }|json_encode(constant('JSON_UNESCAPED_SLASHES'))|raw }}
                </script>
                <script type="application/ld+json">
                    {{ {
                        '@context': 'https://schema.org',
                        '@type': 'WebSite',
                        name: 'Bella Couture',
                        url: app.request.schemeAndHttpHost ~ path('home'),
                        potentialAction: {
                            '@type': 'SearchAction',
                            target: app.request.schemeAndHttpHost ~ path('search') ~ '?q={search_term_string}',
                            'query-input': 'required name=search_term_string'
                        }
                    }|json_encode(constant('JSON_UNESCAPED_SLASHES'))|raw }}
                </script>
            {% endif %}
        {% endblock %}
        <title>{% block title %}{{ default_seo_title }}{% endblock %}</title>
        <link href="{{ asset('css/bootstrap.min.css') }}" rel="stylesheet">
        <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
        <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet">
        <style>
            .swal2-popup.bella-alert {
                border: 1px solid #eadde3;
                border-radius: 18px;
                color: #2f2430;
                box-shadow: 0 18px 55px rgba(87, 49, 65, 0.14);
                font-family: Inter, "Segoe UI", system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
            }

            .swal2-popup.bella-alert .swal2-title {
                color: #2f2430;
                font-weight: 850;
                letter-spacing: 0;
            }

            .swal2-popup.bella-alert .swal2-html-container {
                color: #7b717a;
                line-height: 1.6;
            }

            .swal2-popup.bella-alert .swal2-confirm {
                border-radius: 999px !important;
                background: linear-gradient(135deg, #b23a63, #8f2f52) !important;
                box-shadow: 0 10px 24px rgba(178, 58, 99, 0.24) !important;
                font-weight: 800;
                padding: 0.72rem 1.35rem;
            }

            .swal2-popup.bella-alert .swal2-icon.swal2-success,
            .swal2-popup.bella-alert .swal2-icon.swal2-info,
            .swal2-popup.bella-alert .swal2-icon.swal2-warning,
            .swal2-popup.bella-alert .swal2-icon.swal2-error {
                margin-top: 1.6rem;
            }

            .swal2-popup.bella-alert .swal2-icon.swal2-success {
                border-color: #2f8f72;
                color: #2f8f72;
            }

            .swal2-popup.bella-alert .swal2-icon.swal2-info {
                border-color: #b23a63;
                color: #b23a63;
            }

            @media (max-width: 575.98px) {
                .swal2-popup.bella-alert {
                    width: calc(100% - 2rem) !important;
                    border-radius: 16px;
                }
            }
        </style>
        {% if is_admin_area %}
            <link href="{{ asset('css/admin-ux.css') }}?v=admin-fem-5" rel="stylesheet">
        {% else %}
            <link href="{{ asset('css/front-ux.css') }}?v=front-mobile-3" rel="stylesheet">
        {% endif %}
        {% block stylesheets %}{% endblock %}
    </head>
    <body class="{{ is_admin_area ? 'admin-shell' : 'front-shell' }}">
