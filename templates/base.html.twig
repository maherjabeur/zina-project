        <script>
            (function () {
                const isArabic = {{ app.request.locale == 'ar' ? 'true' : 'false' }};
                const select2Copy = isArabic ? {
                    placeholder: 'اختر...',
                    noResults: 'لا توجد نتائج',
                    searching: 'جاري البحث...',
                    removeAll: 'إفراغ الاختيار',
                    removeItem: 'إزالة',
                    search: 'بحث'
                } : {
                    placeholder: 'Selectionner...',
                    noResults: 'Aucun resultat',
                    searching: 'Recherche...',
                    removeAll: 'Vider la selection',
                    removeItem: 'Retirer',
                    search: 'Rechercher'
                };

                window.initBellaSelect2 = function (root) {
                    if (!window.jQuery || !window.jQuery.fn || !window.jQuery.fn.select2) {
                        return;
                    }

                    const $ = window.jQuery;
                    const context = root || document;
                    const dir = document.documentElement.getAttribute('dir') === 'rtl' ? 'rtl' : 'ltr';

                    $(context).find('select.form-select, select.form-control, select.product-size-select, select.js-select2')
                        .addBack('select.form-select, select.form-control, select.product-size-select, select.js-select2')
                        .not('.form-select-sm')
                        .not('[data-no-select2]')
                        .not(function () {
                            return $(this).closest('table, .table-responsive, .input-group').length > 0;
                        })
                        .each(function () {
                            const $select = $(this);
                            const isMultiple = $select.prop('multiple');
                            const hasEmptyOption = $select.find('option[value=""]').length > 0;
                            const placeholder = $select.data('placeholder') || select2Copy.placeholder;

                            if ($select.data('select2')) {
                                $select.select2('destroy');
                            }

                            $select.select2({
                                width: '100%',
                                dir: dir,
                                closeOnSelect: !isMultiple,
                                placeholder: placeholder,
                                allowClear: isMultiple || (!$select.prop('required') && hasEmptyOption),
                                language: {
                                    noResults: function () { return select2Copy.noResults; },
                                    searching: function () { return select2Copy.searching; },
                                    removeAllItems: function () { return select2Copy.removeAll; },
                                    removeItem: function () { return select2Copy.removeItem; },
                                    search: function () { return select2Copy.search; }
                                }
                            });
                        });
                };

                function init() {
                    window.initBellaSelect2(document);
                }

                if (document.readyState === 'loading') {
                    document.addEventListener('DOMContentLoaded', init);
                } else {
                    init();
                }

                document.addEventListener('turbo:load', init);
            })();
        </script>
