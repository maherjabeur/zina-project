        <script>
            (function () {
                const loader = document.getElementById('bellaPageLoader');
                if (!loader) {
                    return;
                }

                let showTimer = null;
                let hideTimer = null;

                function showLoader(delay) {
                    window.clearTimeout(hideTimer);
                    window.clearTimeout(showTimer);

                    showTimer = window.setTimeout(function () {
                        loader.classList.remove('is-hidden');
                        loader.classList.add('is-active');
                        document.body.classList.add('bella-loader-lock');
                    }, delay || 0);
                }

                function hideLoader(delay) {
                    window.clearTimeout(showTimer);
                    window.clearTimeout(hideTimer);

                    hideTimer = window.setTimeout(function () {
                        loader.classList.add('is-hidden');
                        loader.classList.remove('is-active');
                        document.body.classList.remove('bella-loader-lock');
                    }, delay || 0);
                }

                function isPlainNavigationLink(link) {
                    if (!link || !link.href) {
                        return false;
                    }

                    const href = link.getAttribute('href') || '';
                    if (
                        href === '' ||
                        href.startsWith('#') ||
                        href.startsWith('mailto:') ||
                        href.startsWith('tel:') ||
                        href.startsWith('javascript:') ||
                        link.hasAttribute('download') ||
                        link.target === '_blank' ||
                        link.dataset.noLoader !== undefined ||
                        link.dataset.bsToggle ||
                        link.getAttribute('role') === 'button'
                    ) {
                        return false;
                    }

                    try {
                        const targetUrl = new URL(link.href, window.location.href);
                        return targetUrl.origin === window.location.origin && targetUrl.href !== window.location.href;
                    } catch (error) {
                        return false;
                    }
                }

                window.addEventListener('load', function () {
                    hideLoader(350);
                });

                document.addEventListener('pageshow', function () {
                    hideLoader(150);
                });

                document.addEventListener('click', function (event) {
                    if (event.defaultPrevented || event.button !== 0 || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) {
                        return;
                    }

                    const link = event.target.closest('a');
                    if (isPlainNavigationLink(link)) {
                        showLoader(120);
                    }
                });

                document.addEventListener('submit', function (event) {
                    if (event.defaultPrevented) {
                        return;
                    }

                    const form = event.target;
                    if (!form || form.dataset.noLoader !== undefined || form.target === '_blank') {
                        return;
                    }

                    showLoader(80);
                });

                document.addEventListener('turbo:before-visit', function () {
                    showLoader(80);
                });

                document.addEventListener('turbo:load', function () {
                    hideLoader(120);
                });

                document.addEventListener('turbo:submit-end', function () {
                    hideLoader(120);
                });

                window.addEventListener('beforeunload', function () {
                    showLoader(0);
                });

                window.setTimeout(function () {
                    hideLoader(0);
                }, 5000);
            })();
        </script>
