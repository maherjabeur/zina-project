{% extends 'base.html.twig' %}

{% block title %}Commande - Bella Couture{% endblock %}
{% block robots %}noindex, nofollow{% endblock %}
{% block canonical_url %}{{ app.request.schemeAndHttpHost ~ path('checkout') }}{% endblock %}

{% block body %}
    <section class="bc-page-hero pb-3">
        <div class="container">
            <span class="page-kicker">Derniere etape</span>
            <h1 class="display-6 mb-2">Finaliser ma commande</h1>
            <p class="section-subtitle mb-0">Renseignez vos informations de livraison. Nous confirmerons votre commande avec soin.</p>
        </div>
    </section>

    <div class="container mb-5">
        {% set baseAmount = totalWithDiscount ?? total %}
        {% set shipping = shippingFee %}
        {% set totalWithShipping = baseAmount + shipping %}

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0">Articles commandes</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-flex flex-column gap-3">
                            {% for item in cartData %}
                                <div class="checkout-line d-flex align-items-center gap-3 pb-3 border-bottom">
                                    {% if item.product.images|length > 0 %}
                                        <img src="{{ asset('uploads/products/' ~ item.product.images.first.filename) }}" alt="{{ item.product.name }}">
                                    {% else %}
                                        <img src="{{ asset('images/placeholder.svg') }}" alt="Image non disponible">
                                    {% endif %}
                                    <div class="flex-grow-1">
                                        <h6 class="mb-1">{{ item.product.name }}</h6>
                                        <p class="text-muted small mb-0">
                                            x{{ item.quantity }} - Taille {{ item.size }} - Couleur {{ item.color }}
                                        </p>
                                    </div>
                                    <strong>{{ (item.discountedPrice * item.quantity)|number_format(2) }} DT</strong>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">Informations de livraison</h5>
                    </div>
                    <div class="card-body">
                        <form method="POST" action="{{ path('checkout_process') }}" id="checkoutForm">
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label for="customer_name" class="form-label">Nom complet *</label>
                                    <input type="text" class="form-control" id="customer_name" name="customer_name" autocomplete="name" required>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label for="customer_phone" class="form-label">Telephone *</label>
                                    <input type="tel" class="form-control" id="customer_phone" name="customer_phone" inputmode="numeric" pattern="[0-9]{8}" title="Veuillez entrer un numero de telephone valide (8 chiffres)" autocomplete="tel" required>
                                    <div class="form-text">Format : 12345678</div>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="customer_email" class="form-label">Email (optionnel)</label>
                                <input type="email" class="form-control" id="customer_email" name="customer_email" placeholder="email@exemple.com" autocomplete="email">
                                <div class="form-text">Pour recevoir une confirmation de commande.</div>
                            </div>

                            <div class="mb-3">
                                <label for="shipping_address" class="form-label">Adresse de livraison *</label>
                                <textarea class="form-control" id="shipping_address" name="shipping_address" rows="4" placeholder="Numero, rue, ville..." autocomplete="street-address" required></textarea>
                            </div>

                            <input type="hidden" name="shipping_cost" value="{{ shipping }}">

                            <div class="form-check mb-4">
                                <input class="form-check-input" type="checkbox" id="terms" required>
                                <label class="form-check-label" for="terms">
                                    J'accepte les conditions generales de vente *
                                </label>
                            </div>

                            <div class="d-grid gap-2 d-md-flex">
                                <button type="submit" class="btn btn-primary btn-lg flex-grow-1" id="payButton">
                                    <i class="fas fa-check me-2"></i> Confirmer la commande
                                </button>
                                <a href="{{ path('cart') }}" class="btn btn-outline-primary btn-lg">
                                    Retour panier
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <aside class="col-lg-4">
                <div class="card summary-card">
                    <div class="card-header">
                        <h5 class="mb-0">Votre commande</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span>Sous-total</span>
                            <span>{{ total|number_format(2) }} DT</span>
                        </div>
                        {% if totalDiscount > 0 %}
                            <div class="d-flex justify-content-between mb-2 text-success">
                                <span>Reduction</span>
                                <span>-{{ totalDiscount|number_format(2) }} DT</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span>Apres reduction</span>
                                <span>{{ baseAmount|number_format(2) }} DT</span>
                            </div>
                        {% endif %}
                        <div class="d-flex justify-content-between mb-2">
                            <span>Livraison</span>
                            <span>{{ shipping|number_format(2) }} DT</span>
                        </div>
                        <hr>
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <strong>Total</strong>
                            <strong class="summary-total" id="totalSidebar">{{ totalWithShipping|number_format(2) }} DT</strong>
                        </div>

                        <div class="alert alert-light border small rounded-3">
                            <div class="d-flex align-items-center mb-2">
                                <i class="fas fa-lock text-success me-2"></i>
                                <strong>Commande securisee</strong>
                            </div>
                            <p class="mb-0">Vos informations sont utilisees uniquement pour preparer et livrer votre commande.</p>
                        </div>
                    </div>
                </div>
            </aside>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const form = document.getElementById('checkoutForm');
            const submitButton = document.getElementById('payButton');
            const totalWithShipping = {{ totalWithShipping }};

            submitButton.innerHTML = `<i class="fas fa-check me-2"></i> Confirmer ${totalWithShipping.toFixed(2)} DT`;

            document.getElementById('customer_phone').addEventListener('input', function () {
                this.value = this.value.replace(/[^0-9]/g, '').slice(0, 8);
            });

            form.addEventListener('submit', function (event) {
                const phone = document.getElementById('customer_phone').value;
                const email = document.getElementById('customer_email').value;

                if (phone.length !== 8) {
                    event.preventDefault();
                    alert('Veuillez entrer un numero de telephone valide (8 chiffres).');
                    return;
                }

                if (email && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
                    event.preventDefault();
                    alert('Veuillez entrer un email valide ou laisser le champ vide.');
                    return;
                }

                if (form.checkValidity()) {
                    submitButton.disabled = true;
                    submitButton.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i> Traitement en cours...';
                }
            });
        });
    </script>
{% endblock %}
