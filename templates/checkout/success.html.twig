{% extends 'base.html.twig' %}

{% block title %}Commande confirmee - Bella Couture{% endblock %}
{% block robots %}noindex, nofollow{% endblock %}

{% block body %}
    <div class="container my-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card border-0 shadow text-center">
                    <div class="card-body py-5 px-4 px-lg-5">
                        <span class="contact-icon mb-4" style="width: 76px; height: 76px;">
                            <i class="fas fa-check fa-2x"></i>
                        </span>

                        <span class="page-kicker">Merci</span>
                        <h1 class="h2 section-title mb-3">Commande confirmee</h1>

                        <p class="lead mb-4">
                            Merci <strong>{{ order.customerName }}</strong>, votre commande a bien ete enregistree.
                        </p>

                        <div class="card bg-light border-0 mb-4 text-start">
                            <div class="card-body">
                                <div class="d-flex justify-content-between border-bottom py-2">
                                    <span>Numero de commande</span>
                                    <strong>{{ order.orderNumber }}</strong>
                                </div>
                                <div class="d-flex justify-content-between border-bottom py-2">
                                    <span>Date</span>
                                    <strong>{{ order.createdAt|date('d/m/Y H:i') }}</strong>
                                </div>
                                <div class="d-flex justify-content-between py-2">
                                    <span>Statut</span>
                                    <span class="badge bg-warning text-dark">{{ order.statusLabel }}</span>
                                </div>
                            </div>
                        </div>

                        {% if order.customerEmail %}
                            <p class="text-muted mb-4">Une confirmation peut etre envoyee a <strong>{{ order.customerEmail }}</strong>.</p>
                        {% endif %}

                        <div class="card bg-white border mb-4 text-start">
                            <div class="card-header">
                                <h2 class="h6 mb-0">Articles confirmes</h2>
                            </div>
                            <div class="card-body">
                                {% for item in order.items %}
                                    <div class="d-flex justify-content-between gap-3 py-2 {% if not loop.last %}border-bottom{% endif %}">
                                        <div>
                                            <strong>{{ item.product.name }}</strong>
                                            <div class="text-muted small">
                                                Taille {{ item.size ?? 'Non specifiee' }} - Couleur {{ item.color ?? 'Non specifiee' }} - x{{ item.quantity }}
                                            </div>
                                        </div>
                                        <strong>{{ item.total|number_format(2) }} DT</strong>
                                    </div>
                                {% endfor %}
                            </div>
                        </div>

                        <div class="card bg-light border-0 mb-4 text-start">
                            <div class="card-body">
                                <div class="d-flex justify-content-between border-bottom py-2">
                                    <span>Sous-total articles</span>
                                    <strong>{{ order.itemsTotal|number_format(2) }} DT</strong>
                                </div>
                                {% if order.discount and order.discount > 0 %}
                                    <div class="d-flex justify-content-between border-bottom py-2 text-success">
                                        <span>Remise</span>
                                        <strong>-{{ order.discount|number_format(2) }} DT</strong>
                                    </div>
                                {% endif %}
                                <div class="d-flex justify-content-between border-bottom py-2">
                                    <span>Livraison</span>
                                    <strong>{{ (order.shippingFee ?? 0)|number_format(2) }} DT</strong>
                                </div>
                                <div class="d-flex justify-content-between py-2">
                                    <span>Total final</span>
                                    <strong>{{ order.total|number_format(2) }} DT</strong>
                                </div>
                            </div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-center">
                            <a href="{{ path('home') }}" class="btn btn-primary btn-lg">Retour a l'accueil</a>
                            <a href="{{ path('products') }}" class="btn btn-outline-primary btn-lg">Continuer mes achats</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
