{% extends 'base.html.twig' %}

{% block body %}
    <div class="hero-slider">
        <div id="heroCarousel" class="carousel slide" data-bs-ride="carousel">
            <div class="carousel-inner">
                {% for slide in slider_images %}
                    <div class="carousel-item {{ loop.first ? 'active' : '' }}">
                        <img src="{{ asset('uploads/slider/' ~ slide.filename) }}" class="d-block w-100" alt="{{ slide.title ?? 'Collection Bella Couture' }}">
                        <div class="carousel-caption">
                            <span class="page-kicker text-white">Bella Couture</span>
                            <h2>{{ slide.title|default('Mode feminine elegante') }}</h2>
                            <p>{{ slide.description|default('Des pieces choisies pour composer une allure douce, moderne et assuree.') }}</p>
                            <div class="d-flex gap-2 flex-wrap mt-4">
                                <a href="{{ slide.buttonUrl|default(path('products')) }}" class="btn btn-primary btn-lg">
                                    {{ slide.buttonText|default('Decouvrir la boutique') }}
                                </a>
                                <a href="{{ path('contact') }}" class="btn btn-outline-light btn-lg">Nous contacter</a>
                            </div>
                        </div>
                    </div>
                {% else %}
                    <div class="carousel-item active">
                        <img src="{{ asset('uploads/slider/Soldes-6911b4f6aa588.jpg') }}" class="d-block w-100" alt="Collection Bella Couture">
                        <div class="carousel-caption">
                            <span class="page-kicker text-white">Nouvelle selection</span>
                            <h2>Pieces feminines pour chaque moment</h2>
                            <p>Robes, ensembles, accessoires et essentiels choisis pour un style raffine au quotidien.</p>
                            <a href="{{ path('products') }}" class="btn btn-primary btn-lg">Voir la collection</a>
                        </div>
                    </div>
                {% endfor %}
            </div>

            {% if slider_images|length > 1 %}
                <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon"></span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon"></span>
                </button>
            {% endif %}
        </div>
    </div>

    <section class="container bc-feature-strip">
        <div class="card">
            <div class="row g-0">
                <div class="col-md-4">
                    <div class="bc-feature-item">
                        <i class="fas fa-truck"></i>
                        <div>
                            <strong>Livraison en Tunisie</strong>
                            <p class="mb-0 text-muted small">Une commande preparee avec soin.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="bc-feature-item">
                        <i class="fas fa-gem"></i>
                        <div>
                            <strong>Selection elegante</strong>
                            <p class="mb-0 text-muted small">Des articles mode faciles a porter.</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="bc-feature-item">
                        <i class="fas fa-headset"></i>
                        <div>
                            <strong>Conseil client</strong>
                            <p class="mb-0 text-muted small">Une question ? Nous sommes disponibles.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="container my-5 pt-3">
        <div class="d-flex justify-content-between align-items-end gap-3 mb-4 flex-wrap">
            <div>
                <span class="page-kicker">Selection boutique</span>
                <h2 class="section-title mb-2">Produits en vedette</h2>
                <p class="section-subtitle mb-0">Une selection douce et actuelle pour renouveler votre dressing avec des pieces qui restent faciles a associer.</p>
            </div>
            <a href="{{ path('products') }}" class="btn btn-outline-primary">
                Voir toute la collection
            </a>
        </div>

        {% if productsWithPromotions is defined and productsWithPromotions|length > 0 %}
            <div class="row g-4">
                {% for item in productsWithPromotions %}
                    {% set product = item.product %}
                    {% set promotion = item.promotion %}
                    <div class="col-xl-3 col-lg-4 col-md-6">
                        <div class="card product-card h-100">
                            {% if promotion and promotion.isValid() %}
                                <div class="position-absolute top-0 start-0 m-3">
                                    <span class="badge bg-danger px-3 py-2">-{{ promotion.discount }}%</span>
                                </div>
                            {% endif %}

                            {% if product.images|length > 0 %}
                                <img src="{{ asset('uploads/products/' ~ product.images.first.filename) }}" class="card-img-top" alt="{{ product.name }}" onerror="this.onerror=null; this.src='{{ asset('images/placeholder.svg') }}';">
                            {% else %}
                                <img src="{{ asset('images/placeholder.svg') }}" class="card-img-top" alt="Image non disponible">
                            {% endif %}

                            <div class="card-body d-flex flex-column">
                                <div class="d-flex justify-content-between gap-2 align-items-start mb-2">
                                    <h5 class="card-title mb-0">{{ product.name }}</h5>
                                    {% if product.category %}
                                        <span class="badge bg-info">{{ product.category.name }}</span>
                                    {% endif %}
                                </div>

                                <div class="price-section mb-3">
                                    {% if promotion and promotion.isValid() %}
                                        <span class="text-muted text-decoration-line-through me-2">{{ product.price }} DT</span>
                                        <span class="h5 text-primary mb-0">{{ promotion.calculateDiscountedPrice(product.price)|number_format(2) }} DT</span>
                                        <small class="d-block text-success fw-bold mt-1">{{ promotion.title }}</small>
                                    {% else %}
                                        <span class="h5 text-primary">{{ product.price }} DT</span>
                                    {% endif %}
                                </div>

                                <p class="card-text text-muted small flex-grow-1">
                                    {{ product.description|length > 88 ? product.description|slice(0, 88) ~ '...' : product.description }}
                                </p>

                                <div class="d-flex flex-wrap gap-1 mb-3">
                                    {% for size in product.sizes|slice(0, 4) %}
                                        <span class="badge bg-light text-dark">{{ size.name }}</span>
                                    {% endfor %}
                                    {% for color in product.colors|slice(0, 3) %}
                                        <span class="badge bg-light text-dark">{{ color }}</span>
                                    {% endfor %}
                                </div>

                                <div class="d-grid gap-2 mt-auto">
                                    {% if product.quantity > 0 %}
                                        <a href="{{ path('product_detail', {'id': product.id}) }}" class="btn btn-primary">
                                            <i class="fas fa-ruler-combined me-1"></i> Choisir taille et couleur
                                        </a>
                                    {% else %}
                                        <button class="btn btn-outline-secondary w-100" disabled>Rupture de stock</button>
                                    {% endif %}
                                    <a href="{{ path('product_detail', {'id': product.id}) }}" class="btn btn-outline-primary">Voir details</a>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="bc-empty-state text-center py-5 px-3">
                <i class="fas fa-bag-shopping fa-3x text-primary mb-3"></i>
                <h4>Aucun produit en vedette</h4>
                <p class="text-muted mb-4">Decouvrez tous les produits disponibles dans la boutique.</p>
                <a href="{{ path('products') }}" class="btn btn-primary">Voir les produits</a>
            </div>
        {% endif %}
    </section>

    {% if productsWithPromotions is defined and productsWithPromotions|length > 0 %}
        {% set hasPromotions = false %}
        {% for item in productsWithPromotions %}
            {% if item.promotion and item.promotion.isValid() %}
                {% set hasPromotions = true %}
            {% endif %}
        {% endfor %}

        {% if hasPromotions %}
            <section class="container my-5">
                <div class="card border-0">
                    <div class="card-body p-4 p-lg-5">
                        <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap mb-4">
                            <div>
                                <span class="page-kicker">Offres du moment</span>
                                <h2 class="section-title mb-0">Promotions speciales</h2>
                            </div>
                            <span class="badge bg-danger px-3 py-2">Edition limitee</span>
                        </div>

                        <div class="row g-4">
                            {% for item in productsWithPromotions %}
                                {% if item.promotion and item.promotion.isValid() %}
                                    {% set product = item.product %}
                                    {% set promotion = item.promotion %}
                                    <div class="col-lg-4 col-md-6">
                                        <div class="d-flex gap-3 align-items-center p-3 bg-light rounded-3 h-100">
                                            {% if product.images|length > 0 %}
                                                <img src="{{ asset('uploads/products/' ~ product.images.first.filename) }}" alt="{{ product.name }}" class="rounded-3" style="width: 92px; height: 92px; object-fit: cover;" onerror="this.onerror=null; this.src='{{ asset('images/placeholder.svg') }}';">
                                            {% endif %}
                                            <div>
                                                <span class="badge bg-danger mb-2">-{{ promotion.discount }}%</span>
                                                <h6 class="mb-1">{{ product.name }}</h6>
                                                <p class="mb-2 text-muted small">{{ promotion.title }}</p>
                                                <a href="{{ path('product_detail', {'id': product.id}) }}" class="small fw-bold">Profiter de l'offre</a>
                                            </div>
                                        </div>
                                    </div>
                                {% endif %}
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </section>
        {% endif %}
    {% endif %}
{% endblock %}
