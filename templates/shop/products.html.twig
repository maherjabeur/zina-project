{% extends 'base.html.twig' %}

{% block title %}
    {% if currentCategory %}
        {{ categories|filter(c => c.slug == currentCategory)|first.name }} - Boutique
    {% else %}
        Collection - Bella Couture
    {% endif %}
{% endblock %}
{% block meta_description %}
    {% if currentCategory %}
        Decouvrez la selection {{ categories|filter(c => c.slug == currentCategory)|first.name }} chez Bella Couture: vetements femme, tailles disponibles, couleurs au choix et livraison en Tunisie.
    {% else %}
        Explorez la collection Bella Couture: vetements feminins elegants, articles tendance, tailles et couleurs au choix avec livraison en Tunisie.
    {% endif %}
{% endblock %}
{% block canonical_url %}{{ app.request.schemeAndHttpHost ~ app.request.requestUri }}{% endblock %}

{% block body %}
    <section class="bc-page-hero">
        <div class="container">
            <div class="row align-items-end g-4">
                <div class="col-lg-8">
                    <span class="page-kicker">Boutique</span>
                    <h1 class="display-5 mb-3">
                        {% if currentCategory %}
                            {{ categories|filter(c => c.slug == currentCategory)|first.name }}
                        {% else %}
                            Collection Bella Couture
                        {% endif %}
                    </h1>
                    <p class="section-subtitle mb-0">
                        Explorez une selection feminine et professionnelle, pensee pour trouver rapidement la bonne piece, la bonne taille et la bonne couleur.
                    </p>
                </div>
                <div class="col-lg-4 text-lg-end">
                    <span class="badge bg-light text-dark px-3 py-2">
                        {{ products.getTotalItemCount }} produit(s)
                    </span>
                </div>
            </div>
        </div>
    </section>

    <div class="container mb-5">
        <div class="row g-4">
            <aside class="col-lg-3">
                <div class="card bc-filter-card">
                    <div class="card-header">
                        <div class="d-flex align-items-center justify-content-between">
                            <h5 class="mb-0">Filtres</h5>
                            <i class="fas fa-sliders-h text-primary"></i>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="mb-4">
                            <h6 class="text-uppercase text-muted small fw-bold mb-3">Catégories</h6>
                            <div class="list-group list-group-flush">
                                <a href="{{ path('products', {'size': currentSize}) }}" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center {{ not currentCategory ? 'active' : '' }}">
                                    Toutes
                                    <span class="badge bg-light text-dark">{{ products.getTotalItemCount }}</span>
                                </a>
                                {% for category in categories %}
                                    <a href="{{ path('products', {'category': category.slug, 'size': currentSize}) }}" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center {{ currentCategory == category.slug ? 'active' : '' }}">
                                        <span>
                                            {% if category.icon %}
                                                <i class="{{ category.icon }} me-2" style="color: {{ category.color ?? '#b23a63' }}"></i>
                                            {% endif %}
                                            {{ category.name }}
                                        </span>
                                        <span class="badge bg-light text-dark">{{ categoryProductCounts[category.slug]|default(0) }}</span>
                                    </a>
                                {% endfor %}
                            </div>
                        </div>

                        <div>
                            <h6 class="text-uppercase text-muted small fw-bold mb-3">Tailles</h6>
                            <div class="d-flex flex-wrap gap-2">
                                <a href="{{ path('products', {'category': currentCategory}) }}" class="btn btn-sm {{ not currentSize ? 'btn-primary' : 'btn-outline-primary' }}">Toutes</a>
                                {% for size in sizes %}
                                    <a href="{{ path('products', {'category': currentCategory, 'size': size.code}) }}" class="btn btn-sm {{ currentSize == size.code ? 'btn-primary' : 'btn-outline-primary' }}">
                                        {{ size.name }}
                                    </a>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                </div>
            </aside>

            <main class="col-lg-9">
                <div class="d-flex justify-content-between align-items-center gap-3 mb-4 flex-wrap">
                    <div>
                        <h2 class="h4 section-title mb-1">Articles disponibles</h2>
                        <p class="text-muted mb-0">
                            Page {{ products.getCurrentPageNumber }} sur {{ products.getPageCount }}
                            {% if currentCategory or currentSize %}avec vos filtres actifs{% endif %}
                        </p>
                    </div>
                    {% if currentCategory or currentSize %}
                        <a href="{{ path('products') }}" class="btn btn-outline-primary btn-sm">Reinitialiser</a>
                    {% endif %}
                </div>

                {% if productsWithPromotions|length > 0 %}
                    <div class="row g-4">
                        {% for item in productsWithPromotions %}
                            {% set product = item.product %}
                            {% set promotion = item.promotion %}
                            <div class="col-xl-4 col-md-6">
                                <div class="card product-card h-100">
                                    {% if promotion and promotion.isValid() %}
                                        <div class="position-absolute top-0 start-0 m-3">
                                            <span class="badge bg-danger px-3 py-2">-{{ promotion.discount }}%</span>
                                        </div>
                                    {% endif %}

                                    {% if product.images|length > 0 %}
                                        <img src="{{ asset('uploads/products/' ~ product.images.first.filename) }}" class="card-img-top" alt="{{ product.name }}" onerror="this.onerror=null; this.src='{{ asset('images/placeholder.webp') }}';">
                                    {% else %}
                                        <img src="{{ asset('images/placeholder.webp') }}" class="card-img-top" alt="Image non disponible">
                                    {% endif %}

                                    <div class="card-body d-flex flex-column">
                                        <div class="d-flex justify-content-between gap-2 align-items-start mb-2">
                                            <h5 class="card-title mb-0">{{ product.name }}</h5>
                                            {% if product.category %}
                                                <span class="badge bg-info">{{ product.category.name }}</span>
                                            {% endif %}
                                        </div>

                                        <div class="price-section mb-3">
                                            {% if promotion and promotion.isValid() %}
                                                <span class="text-muted text-decoration-line-through me-2">{{ product.price }} DT</span>
                                                <span class="h5 text-primary mb-0">{{ promotion.calculateDiscountedPrice(product.price)|number_format(2) }} DT</span>
                                                <small class="d-block text-success fw-bold mt-1">{{ promotion.title }}</small>
                                            {% else %}
                                                <span class="h5 text-primary">{{ product.price }} DT</span>
                                            {% endif %}
                                        </div>

                                        <p class="card-text text-muted small flex-grow-1">
                                            {{ product.description|length > 96 ? product.description|slice(0, 96) ~ '...' : product.description }}
                                        </p>

                                        <div class="d-flex flex-wrap gap-1 mb-3">
                                            {% for size in product.sizes|slice(0, 4) %}
                                                <span class="badge bg-light text-dark">{{ size.name }}</span>
                                            {% endfor %}
                                            {% for color in product.colors|slice(0, 3) %}
                                                <span class="badge bg-light text-dark">{{ color }}</span>
                                            {% endfor %}
                                        </div>

                                        <div class="d-grid gap-2 mt-auto">
                                            {% if product.quantity > 0 %}
                                                <a href="{{ path('product_detail', {'id': product.id}) }}" class="btn btn-primary">
                                                    <i class="fas fa-ruler-combined me-1"></i> Choisir taille et couleur
                                                </a>
                                            {% else %}
                                                <button class="btn btn-outline-secondary w-100" disabled>Rupture de stock</button>
                                            {% endif %}
                                            <a href="{{ path('product_detail', {'id': product.id}) }}" class="btn btn-outline-primary">Voir details</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>

                    <div class="d-flex justify-content-center mt-5">
                        {{ knp_pagination_render(products, '@KnpPaginator/Pagination/twitter_bootstrap_v4_pagination.html.twig', {'translation_domain': 'messages'}) }}
                    </div>
                {% else %}
                    <div class="bc-empty-state text-center py-5 px-3">
                        <i class="fas fa-search fa-3x text-primary mb-3"></i>
                        <h3>Aucun produit trouve</h3>
                        <p class="text-muted mb-4">Essayez de modifier vos filtres ou de revenir a toute la collection.</p>
                        <a href="{{ path('products') }}" class="btn btn-primary">Voir tous les produits</a>
                    </div>
                {% endif %}
            </main>
        </div>
    </div>
{% endblock %}
